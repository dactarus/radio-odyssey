---
import Icon from '../components/Icon.astro';
import Layout from '../layouts/Layout.astro';
import PageHero from '../components/PageHero.astro';
import Sidebar from '../components/Sidebar.astro';
import CoherenceExercise from '../components/CoherenceExercise.astro';
import ContentIllustration from '../components/ContentIllustration.astro';
---
<Layout lang="fr" title="Radio Bien-Être en Ligne Gratuite | Radio Odyssey" description="Radio Odyssey, votre radio bien-être en ligne gratuite. Musique positive, cohérence cardiaque et bonne humeur 24h/24.">
  <PageHero
    gradientFrom="#7B2FBE"
    gradientTo="#00C6FF"
    homeLabel="🏠 Accueil"
    breadcrumbCurrent="Radio Odyssey, bien-être en ligne – Musique, énergie positive et respiration"
    title="Radio Bien-être en Ligne"
    text="Musique positive, respiration guidée et cohérence cardiaque — gratuit, 24h/24."
  >
    <Fragment slot="icon">
      <svg viewBox="0 0 48 48" fill="none"><circle cx="24" cy="15" r="7" stroke="white" stroke-width="2.5"/><path d="M10 40C10 31.2 16.3 24 24 24C31.7 24 38 31.2 38 40" stroke="white" stroke-width="2.5" stroke-linecap="round"/><path d="M33 12L37 8M15 12L11 8" stroke="rgba(255,255,255,.6)" stroke-width="2" stroke-linecap="round"/><path d="M18 15C18 15 20 20 24 20C28 20 30 15 30 15" stroke="rgba(255,255,255,.5)" stroke-width="1.8" stroke-linecap="round" fill="none"/></svg>
    </Fragment>
  </PageHero>

  <main class="ro-section">
    <div class="container">
      <div class="row gy-4">
        <div class="col-lg-8">
        
          <div class="content-card">
            <h2>Vous cherchez une radio bien-&#234;tre en ligne gratuite&#160;?</h2>
            <p>Radio Odyssey propose une exp&#233;rience musicale unique m&#234;lant hits des ann&#233;es 80 revisit&#233;s, ambiances modernes et s&#233;quences de coh&#233;rence cardiaque int&#233;gr&#233;es directement dans la programmation.</p>
            <p><strong>Ici, le bien-&#234;tre ne coupe pas l&#8217;&#233;nergie. Il l&#8217;&#233;quilibre.</strong></p>
            <div class="highlight-box">
              <p>&#128139; Vous voulez tout savoir sur une s&#233;ance de respiration guid&#233;e ?<br/>
              <a href="musique-pour-respiration-guidee.html" style="color:var(--ro-purple);font-weight:700;">
                &#8594; Musique pour respiration guid&#233;e &#8211; Radio &amp; coh&#233;rence cardiaque
              </a></p>
            </div>
          </div>

          <CoherenceExercise />

          <div class="content-card">
            <h3 style="font-size:.78rem;font-weight:800;letter-spacing:.14em;text-transform:uppercase;color:#FFD700;margin-bottom:1rem;">COMMENT PRATIQUER</h3>
            <div style="background:rgba(11,28,45,.04);border:1px solid rgba(123,47,190,.1);border-radius:16px;padding:1.2rem;display:flex;flex-direction:column;gap:.9rem;">
              <div style="display:flex;gap:.85rem;align-items:flex-start;">
                <span style="min-width:28px;height:28px;border-radius:50%;border:1.5px solid rgba(30,127,203,.45);color:#7B2FBE;font-family:'Nunito',sans-serif;font-weight:800;font-size:.85rem;display:flex;align-items:center;justify-content:center;flex-shrink:0;">1</span>
                <p style="margin:0;font-size:.91rem;line-height:1.65;color:var(--ro-muted);">Installez-vous confortablement, dos droit, &eacute;paules rel&acirc;ch&eacute;es.</p>
              </div>
              <div style="display:flex;gap:.85rem;align-items:flex-start;">
                <span style="min-width:28px;height:28px;border-radius:50%;border:1.5px solid rgba(30,127,203,.45);color:#7B2FBE;font-family:'Nunito',sans-serif;font-weight:800;font-size:.85rem;display:flex;align-items:center;justify-content:center;flex-shrink:0;">2</span>
                <p style="margin:0;font-size:.91rem;line-height:1.65;color:var(--ro-muted);"><strong style="color:#2b9fd8;">Inspirez</strong> lentement par le nez pendant <strong>5 secondes</strong> en gonflant le ventre.</p>
              </div>
              <div style="display:flex;gap:.85rem;align-items:flex-start;">
                <span style="min-width:28px;height:28px;border-radius:50%;border:1.5px solid rgba(30,127,203,.45);color:#7B2FBE;font-family:'Nunito',sans-serif;font-weight:800;font-size:.85rem;display:flex;align-items:center;justify-content:center;flex-shrink:0;">3</span>
                <p style="margin:0;font-size:.91rem;line-height:1.65;color:var(--ro-muted);"><strong style="color:#38a169;">Expirez</strong> doucement par la bouche pendant <strong>5 secondes</strong>, ventre qui rentre.</p>
              </div>
              <div style="display:flex;gap:.85rem;align-items:flex-start;">
                <span style="min-width:28px;height:28px;border-radius:50%;border:1.5px solid rgba(30,127,203,.45);color:#7B2FBE;font-family:'Nunito',sans-serif;font-weight:800;font-size:.85rem;display:flex;align-items:center;justify-content:center;flex-shrink:0;">4</span>
                <p style="margin:0;font-size:.91rem;line-height:1.65;color:var(--ro-muted);">Suivez le disque&nbsp;: quand il <strong style="color:#2b9fd8;">grandit &rarr; inspirez</strong>, quand il <strong style="color:#38a169;">r&eacute;tr&eacute;cit &rarr; expirez</strong>.</p>
              </div>
            </div>
          </div>

          <div class="content-card">
            <h2>Les bienfaits</h2>
            <div class="row g-3">
              <div class="col-6">
                <div style="background:linear-gradient(135deg,rgba(123,47,190,.08),rgba(0,198,255,.06));border-radius:14px;padding:1rem;text-align:center;">
                  <div style="font-size:1.6rem;margin-bottom:.4rem;">&#129335;</div>
                  <div style="font-family:'Nunito',sans-serif;font-weight:800;font-size:.88rem;">R&eacute;duction du stress</div>
                  <div style="font-size:.75rem;color:var(--ro-muted);margin-top:.2rem;">Respiration ralentie, moment de calme</div>
                </div>
              </div>
              <div class="col-6">
                <div style="background:linear-gradient(135deg,rgba(255,60,172,.08),rgba(123,47,190,.06));border-radius:14px;padding:1rem;text-align:center;">
                  <div style="font-size:1.6rem;margin-bottom:.4rem;">&#10084;&#65039;</div>
                  <div style="font-family:'Nunito',sans-serif;font-weight:800;font-size:.88rem;">C&#x153;ur en coh&eacute;rence</div>
                  <div style="font-size:.75rem;color:var(--ro-muted);margin-top:.2rem;">Synchronisation c&#x153;ur-respiration</div>
                </div>
              </div>
              <div class="col-6">
                <div style="background:linear-gradient(135deg,rgba(0,198,255,.08),rgba(30,127,203,.06));border-radius:14px;padding:1rem;text-align:center;">
                  <div style="font-size:1.6rem;margin-bottom:.4rem;">&#129504;</div>
                  <div style="font-family:'Nunito',sans-serif;font-weight:800;font-size:.88rem;">Clart&eacute; mentale</div>
                  <div style="font-size:.75rem;color:var(--ro-muted);margin-top:.2rem;">Concentration et m&eacute;moire</div>
                </div>
              </div>
              <div class="col-6">
                <div style="background:linear-gradient(135deg,rgba(255,215,0,.1),rgba(255,154,60,.07));border-radius:14px;padding:1rem;text-align:center;">
                  <div style="font-size:1.6rem;margin-bottom:.4rem;">&#128564;</div>
                  <div style="font-family:'Nunito',sans-serif;font-weight:800;font-size:.88rem;">Meilleur sommeil</div>
                  <div style="font-size:.75rem;color:var(--ro-muted);margin-top:.2rem;">Favorise l'endormissement</div>
                </div>
              </div>
            </div>
          </div>

          <div class="content-card">
            <h2>Horaires de diffusion</h2>
            <div style="display:flex;flex-wrap:wrap;gap:.4rem;">
              <span class="tag-pill">7H &bull; 3min</span><span class="tag-pill">8H &bull; 3min</span>
              <span class="tag-pill">9H &bull; 3min</span><span class="tag-pill">10H &bull; 1min</span>
              <span class="tag-pill">11H &bull; 1min</span><span class="tag-pill">12H &bull; 3min</span>
              <span class="tag-pill">13H &bull; 3min</span><span class="tag-pill">14H &bull; 1min</span>
              <span class="tag-pill">15H &bull; 1min</span><span class="tag-pill">16H &bull; 1min</span>
              <span class="tag-pill">17H &bull; 1min</span><span class="tag-pill">18H &bull; 3min</span>
              <span class="tag-pill">19H &bull; 3min</span>
            </div>
          </div>


          <div class="content-card">
            <h2>Radio Odyssey, une radio bien-&#234;tre qui fait du bien &#127925;</h2>
            <p>Dans un monde o&#249; tout va toujours plus vite, prendre quelques minutes pour respirer et &#233;couter de la musique positive peut changer une journ&#233;e enti&#232;re.</p>
            <p>Radio Odyssey diffuse 24h/24 une s&#233;lection de titres entra&#238;nants, positifs et inspirants, associ&#233;e &#224; des s&#233;quences de coh&#233;rence cardiaque.</p>
  
          <div class="highlight-box" style="margin-top:1rem;">
            <strong>S&#233;ances de 3 minutes :</strong> 7h, 8h, 9h, 12h, 13h, 18h, 19h.<br/>
            <strong>S&#233;ances de 1 minute :</strong> 10h, 11h, 14h, 15h, 16h, 17h.
          </div>

          </div>

          <ContentIllustration gradientFrom="#7B2FBE" gradientTo="#00C6FF" caption="Respirer. Écouter. Sourire.">
            <Fragment slot="icon">
              <svg viewBox="0 0 48 48" fill="none"><circle cx="24" cy="15" r="7" stroke="white" stroke-width="2.5"/><path d="M10 40C10 31.2 16.3 24 24 24C31.7 24 38 31.2 38 40" stroke="white" stroke-width="2.5" stroke-linecap="round"/><path d="M33 12L37 8M15 12L11 8" stroke="rgba(255,255,255,.6)" stroke-width="2" stroke-linecap="round"/><path d="M18 15C18 15 20 20 24 20C28 20 30 15 30 15" stroke="rgba(255,255,255,.5)" stroke-width="1.8" stroke-linecap="round" fill="none"/></svg>
            </Fragment>
          </ContentIllustration>

          <div class="content-card">
            <h2>Pourquoi &#233;couter Radio Odyssey&#160;?</h2>
            <ul>
              <li>&#10003; R&#233;duire le stress quotidien</li>
              <li>&#10003; Favoriser la concentration</li>
              <li>&#10003; Travailler dans une ambiance positive</li>
              <li>&#10003; Retrouver un rythme plus calme</li>
              <li>&#10003; S&#8217;accorder une pause bien-&#234;tre</li>
            </ul>
          </div>

          <div class="content-card">
            <h2>Respirer. &#201;couter. Sourire. &#128153;</h2>
            <p>La coh&#233;rence cardiaque repose sur un principe simple&nbsp;: synchroniser sa respiration avec un rythme r&#233;gulier. Quelques minutes suffisent pour favoriser la d&#233;tente, retrouver de l&#8217;&#233;nergie et am&#233;liorer son bien-&#234;tre.</p>
            <p>La cr&#233;dibilit&#233; de Radio Odyssey repose en grande partie sur l&#8217;expertise scientifique d&#8217;<strong>Elisabeth B&#233;lot Grimaud</strong>, docteure en sciences psychologiques, chercheuse associ&#233;e (Universit&#233; Paris Nanterre) et sp&#233;cialiste de la sant&#233; mentale positive.</p>
            <p>Son approche &#171;&#160;int&#233;grative&#160;&#187; combine&nbsp;:</p>
            <ul>
              <li><strong>Neurosciences et psychologie cognitive</strong> : Pour comprendre les m&#233;canismes du stress et de l&#8217;&#233;quilibre &#233;motionnel.</li>
              <li><strong>Micronutrition et physiologie</strong> : Pour une vision globale de la sant&#233; (corps-esprit).</li>
              <li><strong>Pratiques respiratoires</strong> : Pour une application concr&#232;te et imm&#233;diate de r&#233;gulation du syst&#232;me nerveux.</li>
            </ul>
          </div>

          <div class="content-card">
            <h2>Une radio pour tous les moments de la journ&#233;e</h2>
            <ul>
              <li>Au bureau</li>
              <li>&#192; la maison</li>
              <li>En t&#233;l&#233;travail</li>
              <li>Pendant la lecture</li>
              <li>Lors d&#8217;un moment de d&#233;tente</li>
            </ul>
            <p>Radio Odyssey vous accompagne partout.</p>

            <h3 style="margin-top:1.2rem;">Pourquoi choisir Radio Odyssey&#160;?</h3>
            <ul>
              <li>&#127925; Musique positive</li>
              <li>&#127758; Accessible partout dans le monde</li>
              <li>&#128241; Smartphone, tablette et ordinateur</li>
              <li>&#128153; S&#233;quences de coh&#233;rence cardiaque int&#233;gr&#233;es</li>
              <li>&#128336; &#201;coute gratuite 24h/24</li>
            </ul>
          </div>

          <div class="content-card">
            <h2>Les bienfaits de la musique associ&#233;e &#224; la respiration</h2>
            <p>La musique agit directement sur le rythme cardiaque et le syst&#232;me nerveux. Associ&#233;e &#224; la coh&#233;rence cardiaque (6 respirations par minute), elle peut&nbsp;:</p>
            <ul>
              <li>Apaiser le syst&#232;me nerveux</li>
              <li>Am&#233;liorer la clart&#233; mentale</li>
              <li>Stabiliser l&#8217;humeur</li>
              <li>Favoriser un &#233;tat d&#8217;attention calme</li>
            </ul>
  
          <div class="highlight-box" style="margin-top:1rem;">
            <strong>S&#233;ances de 3 minutes :</strong> 7h, 8h, 9h, 12h, 13h, 18h, 19h.<br/>
            <strong>S&#233;ances de 1 minute :</strong> 10h, 11h, 14h, 15h, 16h, 17h.
          </div>

          </div>

          <div class="page-cta-bar">
            <h3>Votre journ&#233;e commence bien mieux avec Radio Odyssey</h3>
            <a href="#" onclick="roPlayNow(event)" class="btn-hero">
              <Icon name="broadcast-pin" /> &#201;couter maintenant
            </a>
          </div>
        </div>
        <div class="col-lg-4">
          <Sidebar />
        </div>
      </div>
    </div>
  </main>
</Layout>
