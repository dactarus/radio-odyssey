---
import Layout from '../layouts/Layout.astro';
import PageHero from '../components/PageHero.astro';
import Sidebar from '../components/Sidebar.astro';
import { ARTISTS } from '../data/artists.js';

// Les 15 premières fiches créées (voir SEO_BLUEPRINT.md §6) — chacune a
// sa propre page /artiste-[slug].html et est donc mise en avant ici.
const flagship = ARTISTS.map((a) => ({
  name: a.name,
  slug: a.slug,
  note: a.facts[0],
  example: a.tracks[0],
}));

// Artistes très présents sur l'antenne, pas encore dotés de leur propre
// fiche (lots suivants — voir SEO_BLUEPRINT.md).
const alsoOnAir = [
  'Jennifer Lopez', 'Taylor Swift', 'Zazie', 'Pascal Obispo', 'Justin Bieber',
  'Indochine', 'Bebe Rexha', 'Ariana Grande', 'Coldplay', 'Calvin Harris',
  'Alicia Keys', 'Dua Lipa', 'The Weeknd', 'Harry Styles', 'Sia', 'Sting',
  'Sabrina Carpenter', 'Katy Perry', 'Miley Cyrus', 'Céline Dion',
  'Simple Minds', 'Maroon 5', 'Phil Collins', 'Robbie Williams', 'Wham!',
  'Karol G', 'Vanessa Paradis', 'Jean-Jacques Goldman', 'Stromae', 'Elton John',
];
---
<Layout
  lang="fr"
  title="Les Artistes Diffusés sur Radio Odyssey — Pop, Dance & Tubes Remixés"
  description="Madonna, Shakira, Michael Jackson, Ed Sheeran, Daft Punk, David Guetta... Découvrez les artistes qui rythment l'antenne de Radio Odyssey, entre golds remixés, années 80 et nouveautés."
>
  <PageHero
    gradientFrom="#FFD700"
    gradientTo="#7B2FBE"
    homeLabel="🏠 Accueil"
    breadcrumbCurrent="Les artistes diffusés sur Radio Odyssey"
    title="Les Artistes Diffusés sur Radio Odyssey"
    text="Madonna, Shakira, Michael Jackson, Ed Sheeran... découvrez les artistes qui rythment l'antenne, entre tubes remixés et nouveautés du moment."
  >
    <Fragment slot="icon">
      <svg viewBox="0 0 48 48" fill="none"><circle cx="20" cy="26" r="15" stroke="white" stroke-width="2.5"/><circle cx="20" cy="26" r="5" stroke="white" stroke-width="2"/><circle cx="20" cy="26" r="1.3" fill="white"/><path d="M28 14L38 10V22L28 26Z" stroke="white" stroke-width="1.8" stroke-linejoin="round" fill="none"/></svg>
    </Fragment>
  </PageHero>

  <main class="ro-section">
    <div class="container">
      <div class="row gy-4">
        <div class="col-lg-8">

          <div class="content-card">
            <h2>Une programmation qui mélange trois univers</h2>
            <p>La sélection musicale de Radio Odyssey s'articule autour de trois grandes familles, chacune annoncée sur l'antenne par un jingle dédié, dynamique et chantant :</p>
            <ul>
              <li><strong>Les nouveautés</strong> — les tubes en puissance du moment, ceux qui montent dans les charts</li>
              <li><strong>Les golds</strong> — des titres très connus, à forte valeur émotionnelle, souvent ressortis dans des versions remixées récentes pour leur redonner un côté actuel</li>
              <li><strong>Les années 80</strong> — des classiques, eux aussi très souvent remixés</li>
            </ul>
            <p>Le fil conducteur : de la pop, de la dance et quelques ballades puissantes — pas de rap urbain sur l'antenne. Un habillage sonore professionnel et joyeux fait le lien entre chaque titre, pour une ambiance qui reste dynamique et positive du début à la fin.</p>
          </div>

          <div class="content-card">
            <h3 style="font-size:.78rem;font-weight:800;letter-spacing:.14em;text-transform:uppercase;color:#7B2FBE;margin-bottom:1rem;">LES ARTISTES PHARES DE L'ANTENNE</h3>
            <div class="row g-3">
              {flagship.map((a) => (
                <div class="col-md-6">
                  <a href={`/artiste-${a.slug}.html`} style="display:block;text-decoration:none;color:inherit;background:linear-gradient(135deg,rgba(255,215,0,.08),rgba(123,47,190,.06));border-radius:14px;padding:1rem 1.2rem;height:100%;transition:transform .2s;">
                    <div style="font-family:'Nunito',sans-serif;font-weight:800;font-size:1rem;color:var(--ro-dark);">{a.name} <i class="bi bi-arrow-right" style="font-size:.75rem;color:var(--ro-purple);"></i></div>
                    <div style="font-size:.82rem;color:var(--ro-muted);margin-top:.2rem;">{a.note}</div>
                    <div style="font-size:.76rem;color:var(--ro-purple);margin-top:.5rem;font-style:italic;">♪ {a.example}</div>
                  </a>
                </div>
              ))}
            </div>
          </div>

          <div class="content-card">
            <h2>Ils sont aussi très présents sur l'antenne</h2>
            <p style="margin-bottom:1rem;">D'après notre relevé de programmation de juin 2026 — plus de <strong>12 900 titres diffusés</strong> et près de <strong>950 artistes différents</strong> — voici d'autres noms que vous entendrez régulièrement (fiches à venir) :</p>
            <div style="display:flex;flex-wrap:wrap;gap:.4rem;">
              {alsoOnAir.map((name) => (
                <span class="tag-pill">{name}</span>
              ))}
              <span class="tag-pill">et bien d'autres…</span>
            </div>
          </div>

          <div class="content-card">
            <h2>Où retrouver ces artistes sur l'antenne ?</h2>
            <p>Les remixes des années 80 sont particulièrement mis à l'honneur sur notre page <a href="/radio-annees-80-en-ligne.html" style="color:var(--ro-purple);font-weight:700;">radio années 80 en ligne</a>, tandis que la dance et les nouveautés dominent sur <a href="/radio-dance-energisante.html" style="color:var(--ro-purple);font-weight:700;">radio dance énergisante</a>. Mais tous les styles se croisent en continu sur l'antenne principale, 24h/24.</p>
          </div>

          <div class="page-cta-bar">
            <h3>Découvrez qui passe en ce moment</h3>
            <a href="#" onclick="roPlayNow(event)" class="btn-hero">
              <i class="bi bi-broadcast-pin"></i> Écouter Radio Odyssey
            </a>
          </div>

        </div>
        <div class="col-lg-4">
          <Sidebar />
        </div>
      </div>
    </div>
  </main>
</Layout>
