---
import Layout from '../layouts/Layout.astro';
import { NAV_CATEGORIES } from '../data/navigation.js';

const title = 'Radio Odyssey – Positive Web Radio | Bien-être & Bonne Humeur 24h/24';
const description = "Radio Odyssey, votre web radio 100% positive ! Hits des années 80, dance, easy listening, cohérence cardiaque. Gratuite, sans pub, non-stop 24h/24.";
const ogTitle = 'Radio Odyssey – Positive Web Radio';
const ogDescription = "Web radio musicale positive en streaming 24h/24. Joyeuse, bien-être, gratuite.";
---
<Layout lang="fr" title={title} description={description} ogTitle={ogTitle} ogDescription={ogDescription}>
  <Fragment slot="head">
  <style is:global>
    /* ── SVG icon wrappers ── */
    .svg-icon {
      display: flex; align-items: center; justify-content: center;
      flex-shrink: 0;
    }
    .svg-icon svg { width: 100%; height: 100%; display: block; }

    /* Feature card icon circles */
    .fc-icon {
      width: 72px; height: 72px; border-radius: 50%;
      margin: 0 auto 1.2rem;
      display: flex; align-items: center; justify-content: center;
    }
    .fc-icon svg { width: 40px; height: 40px; }

    /* Page card icon */
    .pg-icon { width: 52px; height: 52px; border-radius: 14px; }
    .pg-icon svg { width: 28px; height: 28px; }

    /* Schedule icon */
    .schedule-icon svg { width: 28px; height: 28px; }

    /* Social icon */
    .social-btn svg { width: 22px; height: 22px; flex-shrink: 0; }

    /* Hero CTA row */
    .hero-cta { display: flex; flex-wrap: wrap; gap: 1rem; align-items: center; margin-bottom: .5rem; }

    /* Hero : sous-titre H1 + paragraphe SEO */
    .hero-subtitle {
      font-family: 'Nunito', sans-serif;
      font-weight: 700;
      font-size: 1.05rem;
      color: #fff;
      opacity: .92;
      letter-spacing: .01em;
      margin: -.5rem 0 1.1rem;
      text-shadow: 0 1px 8px rgba(0,0,0,.2);
    }
    .hero-seo-text {
      font-size: .95rem;
      line-height: 1.7;
      color: rgba(255,255,255,.8);
      max-width: 560px;
      margin-top: 1.5rem;
    }

    /* Grille des programmes — chaque créneau renvoie vers sa page dédiée */
    a.schedule-row { text-decoration: none; color: inherit; }
    a.schedule-row .schedule-arrow { margin-left: auto; color: var(--ro-purple); opacity: .45; transition: opacity .2s, transform .2s; flex-shrink: 0; }
    a.schedule-row:hover .schedule-arrow { opacity: 1; transform: translateX(3px); }

    /* ── ESPACE SOUS LE PLAYER (desktop) ────────────────────────────
       Le player RadioKing déployé (avec pochette) dépasse la hauteur
       déclarée de la barre (~180px réels contre 105px). Même besoin
       que sur les pages secondaires (170px) pour que le méga-menu ne
       soit pas caché derrière le lecteur.
    ─────────────────────────────────────────────────────────────── */
    body {
      padding-top: 190px;
    }
    html {
      scroll-padding-top: 190px;
    }

    /* ── PLAYER MOBILE COMPACT ─────────────────────────────────────
       Géré dans style.css via .rk-desktop / .rk-mobile-btn
       Ici : uniquement les overrides propres à la page d'accueil
    ─────────────────────────────────────────────────────────────── */
    @media (max-width: 767px) {
      /* Barre compacte 62px */
      #topRadioBar {
        height: 62px !important;
        padding: 0 8px !important;
        gap: 8px !important;
      }
      body {
        padding-top: 62px !important;
      }
      html {
        scroll-padding-top: 60px !important;
      }
      .bar-logo { margin-left: 0; }
      .bar-logo-img {
        width: 42px !important;
        height: 42px !important;
      }
      .bar-burger {
        width: 36px !important;
        height: 36px !important;
        font-size: 1.2rem !important;
        margin-right: 0 !important;
      }
    }
  </style>
  <script is:inline type="application/ld+json">
  [
    {
      "@context": "https://schema.org",
      "@type": "RadioStation",
      "name": "Radio Odyssey",
      "alternateName": "La Positive Radio",
      "url": "https://www.radio-odyssey.com",
      "logo": {
        "@type": "ImageObject",
        "url": "https://www.radio-odyssey.com/assets/images/logo.png",
        "width": 512,
        "height": 512
      },
      "image": "https://www.radio-odyssey.com/assets/images/logo.png",
      "description": "Radio Odyssey est une webradio positive 100% gratuite diffusant des hits des années 80 revisités, de la dance, du easy listening et des séquences de cohérence cardiaque, 24h/24 et 7j/7.",
      "foundingDate": "2025-01-19",
      "address": {
        "@type": "PostalAddress",
        "addressCountry": "FR"
      },
      "contactPoint": {
        "@type": "ContactPoint",
        "email": "odysseylaradio@gmail.com",
        "contactType": "customer support"
      },
      "sameAs": [
        "https://www.facebook.com/profile.php?id=61588289230589",
        "https://www.instagram.com/radio_odyssey_france/",
        "https://x.com/Odysseylaradio",
        "https://www.youtube.com/channel/UCodzZ_dhFdJwQ90nZzVHluw",
        "https://tunein.com/radio/RADIO-ODYSSEY-s339104/",
        "https://link.radioking.com/radio-odyssey"
      ],
      "potentialAction": {
        "@type": "ListenAction",
        "target": {
          "@type": "EntryPoint",
          "urlTemplate": "https://link.radioking.com/radio-odyssey",
          "actionPlatform": [
            "https://schema.org/DesktopWebPlatform",
            "https://schema.org/MobileWebPlatform",
            "https://schema.org/IOSPlatform",
            "https://schema.org/AndroidPlatform"
          ]
        },
        "expectsAcceptanceOf": {
          "@type": "Offer",
          "price": "0",
          "priceCurrency": "EUR",
          "availability": "https://schema.org/InStock"
        }
      }
    },
    {
      "@context": "https://schema.org",
      "@type": "MusicGroup",
      "name": "Artistes diffusés sur Radio Odyssey",
      "genre": ["Pop", "Synthpop", "Dance", "New Wave", "Easy Listening"],
      "url": "https://www.radio-odyssey.com",
      "description": "Sélection musicale de Radio Odyssey : hits des années 80 revisités, dance moderne et easy listening."
    }
  ]
  </script>
  </Fragment>



<!-- ============================================================
     HERO
     ============================================================ -->
<section class="hero">
  <div class="hero-bubble hero-bubble-1"></div>
  <div class="hero-bubble hero-bubble-2"></div>
  <div class="container">
    <div class="row align-items-center gy-5">

      <div class="col-lg-7 hero-content">
        <div class="hero-eyebrow">
          <span class="hero-live-dot"></span>
          EN DIRECT &nbsp;·&nbsp; LIVE NOW
        </div>
        <h1>Radio Odyssey<br/><em>La Positive Radio !</em></h1>
        <p class="hero-subtitle">Musique positive • Bien-être • Cohérence cardiaque</p>
        <p class="tagline">
          Le meilleur des hits — des années 80 à aujourd'hui, non-stop 24h/24<br/>
          <span style="font-size:.92rem;opacity:.85;font-style:italic;">
            The best hits — from the 80s to today, non-stop 24/7
          </span>
        </p>
        <div class="hero-cta">
          <a href="#" onclick="roPlayNow(event)" class="btn-hero">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polygon points="10 8 16 12 10 16 10 8" fill="currentColor" stroke="none"/></svg>
            ÉCOUTER EN DIRECT
          </a>
          <a href="https://app.radio-odyssey.com/" target="_blank" rel="noopener" class="btn-hero-ghost">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="5" y="2" width="14" height="20" rx="2" ry="2"/><line x1="12" y1="18" x2="12.01" y2="18"/></svg>
            App Mobile
          </a>
        </div>
        <div class="hero-stats">
          <div class="hero-stat">24/7<span>Musique non-stop</span></div>
          <div class="hero-stat">80's<span>Tubes remixés</span></div>
          <div class="hero-stat">100%<span>Gratuit &amp; positif</span></div>
          <div class="hero-stat">0<span>Publicités</span></div>
        </div>
        <a href="/elisabeth-belot-grimaud-radio-odyssey.html" style="display:inline-flex;align-items:center;gap:.5rem;margin-top:1.4rem;text-decoration:none;background:var(--ro-gold);border:1px solid rgba(0,0,0,.06);border-radius:999px;padding:.42rem 1.2rem;font-family:'Nunito',sans-serif;font-weight:800;font-size:.82rem;letter-spacing:.02em;color:#2D2D3A;box-shadow:0 6px 20px rgba(0,0,0,.18);">
          <i class="bi bi-patch-check-fill" style="color:var(--ro-purple);"></i>
          Cohérence cardiaque conçue avec une Docteure en psychologie
        </a>
        <p class="hero-seo-text">
          Radio Odyssey est une web radio positive gratuite qui associe musique et bien-être&nbsp;:
          hits des années 80 remixés, dance énergisante, easy listening et nouveautés se mêlent
          à des séquences de cohérence cardiaque diffusées chaque heure, sans aucune publicité.
          Que vous cherchiez une radio pour vous détendre, une musique pour vous concentrer au
          travail ou simplement une programmation joyeuse pour toute la famille, Radio Odyssey
          vous accompagne 24h/24 et 7j/7, sur mobile, en voiture ou sur enceinte connectée.
          Découvrez une nouvelle façon d'écouter la radio&nbsp;: positive, gratuite, et pensée
          pour votre équilibre au quotidien.
        </p>
      </div>

      <div class="col-lg-5 text-center">
        <img class="hero-logo-img"
             src="assets/images/logo.png"
             alt="Radio Odyssey"/>
      </div>
    </div>
  </div>
</section>

<!-- ============================================================
     TITRES RÉCENTS — En ce moment sur Radio Odyssey
     ============================================================ -->
<section id="now-playing-section">

  <!-- Vague de transition depuis le hero -->
  <div style="line-height:0;">
    <svg viewBox="0 0 1440 54" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none"
         style="width:100%;height:54px;display:block;">
      <path d="M0,32 C360,60 1080,0 1440,28 L1440,54 L0,54 Z"
            fill="#1a0d2e"/>
    </svg>
  </div>

  <div style="background:linear-gradient(135deg,#1a0d2e 0%,#2d1060 40%,#1a0d2e 100%);padding:2.5rem 0 3.5rem;">
    <div class="container">

      <!-- En-tête -->
      <div style="text-align:center;margin-bottom:2rem;">
        <div style="display:inline-flex;align-items:center;gap:.55rem;
          background:rgba(255,255,255,.08);border:1px solid rgba(255,255,255,.15);
          border-radius:999px;padding:.4rem 1.2rem;margin-bottom:1rem;">
          <span style="width:8px;height:8px;border-radius:50%;background:#ff2b2b;
            flex-shrink:0;animation:pulse-dot 1.4s infinite;"></span>
          <span style="font-family:'Nunito',sans-serif;font-weight:700;font-size:.75rem;
            letter-spacing:.1em;color:rgba(255,255,255,.9);">EN CE MOMENT SUR RADIO ODYSSEY</span>
        </div>
        <h2 style="font-family:'Nunito',sans-serif;font-weight:900;
          font-size:clamp(1.4rem,3vw,2rem);color:#fff;margin:0;line-height:1.15;">
          Les <span style="background:linear-gradient(135deg,#FF3CAC,#FFD700);
            -webkit-background-clip:text;-webkit-text-fill-color:transparent;
            background-clip:text;">4 derniers titres</span> diffusés
        </h2>
      </div>

      <!-- ★ Widget RadioKing officiel ★ -->
      <div id="rk-played-tracks-widget"
           data-id="radio-odyssey"
           data-count="4"
           data-date="1"
           data-buy="0">
      </div>
      <script is:inline type="text/javascript"
              src="https://widget.radioking.io/played-tracks/build/script.min.js">
      </script>

      <p style="text-align:center;margin-top:1.6rem;margin-bottom:0;
        font-size:.76rem;color:rgba(255,255,255,.3);font-family:'Nunito',sans-serif;">
        ↻ Mis à jour automatiquement
      </p>

    </div>
  </div>

  <!-- Vague de transition vers section blanche -->
  <div style="line-height:0;background:#1a0d2e;">
    <svg viewBox="0 0 1440 54" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none"
         style="width:100%;height:54px;display:block;">
      <path d="M0,26 C480,54 960,0 1440,30 L1440,54 L0,54 Z"
            fill="#FAFAFA"/>
    </svg>
  </div>

</section>

<!-- Surcharge CSS du widget RadioKing pour l'intégrer au thème sombre -->
<style is:global>
/* ── Widget RadioKing — Titres récents ── */
#rk-played-tracks-widget * {
  font-family: 'Nunito', sans-serif !important;
  box-sizing: border-box !important;
}

/* Wrapper liste : 4 colonnes */
#rk-played-tracks-widget ul,
#rk-played-tracks-widget .rk-tracks-list {
  display: grid !important;
  grid-template-columns: repeat(4, 1fr) !important;
  gap: 1rem !important;
  list-style: none !important;
  padding: 0 !important;
  margin: 0 !important;
}

/* Chaque carte : flex ROW (pochette gauche, infos droite) */
#rk-played-tracks-widget li,
#rk-played-tracks-widget .rk-played-track-item {
  background: rgba(255,255,255,.07) !important;
  border: 1px solid rgba(255,255,255,.13) !important;
  border-radius: 18px !important;
  padding: .9rem !important;
  display: flex !important;
  flex-direction: row !important;
  align-items: center !important;
  gap: .85rem !important;
  transition: transform .25s, background .25s !important;
  overflow: hidden !important;
}
#rk-played-tracks-widget li:hover,
#rk-played-tracks-widget .rk-played-track-item:hover {
  transform: translateY(-4px) !important;
  background: rgba(255,255,255,.13) !important;
}

/* ★ Pochette : taille fixe 72×72px — comme le logo du player ★ */
#rk-played-tracks-widget img,
#rk-played-tracks-widget .rk-track-cover {
  width: 72px !important;
  height: 72px !important;
  min-width: 72px !important;
  object-fit: cover !important;
  border-radius: 10px !important;
  box-shadow: 0 4px 14px rgba(0,0,0,.5) !important;
  flex-shrink: 0 !important;
}

/* Titre du morceau */
#rk-played-tracks-widget .rk-track-title,
#rk-played-tracks-widget strong {
  font-weight: 800 !important;
  font-size: .9rem !important;
  color: #fff !important;
  display: block !important;
  white-space: nowrap !important;
  overflow: hidden !important;
  text-overflow: ellipsis !important;
}

/* Artiste */
#rk-played-tracks-widget .rk-track-artist,
#rk-played-tracks-widget span:not(.rk-track-date) {
  font-size: .78rem !important;
  color: rgba(255,255,255,.6) !important;
  white-space: nowrap !important;
  overflow: hidden !important;
  text-overflow: ellipsis !important;
}

/* Date/heure */
#rk-played-tracks-widget .rk-track-date,
#rk-played-tracks-widget time {
  font-size: .68rem !important;
  color: rgba(255,255,255,.35) !important;
}

/* Premier titre : badge EN COURS */
#rk-played-tracks-widget li:first-child::before,
#rk-played-tracks-widget .rk-played-track-item:first-child::before {
  content: '▶ EN COURS' !important;
  display: inline-block !important;
  background: rgba(255,60,172,.2) !important;
  border: 1px solid rgba(255,60,172,.4) !important;
  border-radius: 999px !important;
  padding: .18rem .65rem !important;
  font-size: .62rem !important;
  font-weight: 800 !important;
  letter-spacing: .08em !important;
  color: #FF3CAC !important;
  margin-bottom: .25rem !important;
}

/* Responsive */
@media (max-width: 900px) {
  #rk-played-tracks-widget ul,
  #rk-played-tracks-widget .rk-tracks-list {
    grid-template-columns: repeat(2,1fr) !important;
  }
}
@media (max-width: 480px) {
  #rk-played-tracks-widget ul,
  #rk-played-tracks-widget .rk-tracks-list {
    grid-template-columns: repeat(2,1fr) !important;
    gap: .6rem !important;
  }
}

/* ── Widget RadioKing — sélecteurs à jour (juillet 2026) ──────────
   RadioKing a renommé ses classes internes (modules CSS avec hash,
   ex: src-components-played-tracks__title--hTeYp). On cible via
   [class*="..."] pour rester robuste si le hash change, tout en
   gardant les règles ci-dessus au cas où l'ancien balisage revienne.
─────────────────────────────────────────────────────────────────── */

/* Cacher le formulaire de recherche par date/heure */
#rk-played-tracks-widget [class*="played-tracks__form--"] {
  display: none !important;
}

/* Le wrapper du widget (RadioKing) a son propre fond BLANC intégré —
   sur ce fond, le texte blanc du titre/artiste devient invisible.
   On le neutralise pour laisser apparaître le fond sombre de la
   section et rendre le texte lisible. */
#rk-played-tracks-widget [class*="articleCard"] {
  background: transparent !important;
  box-shadow: none !important;
  padding: 0 !important;
}

/* Grille 4 colonnes */
#rk-played-tracks-widget #rk-played-tracks-table {
  display: grid !important;
  grid-template-columns: repeat(4, 1fr) !important;
  gap: 1rem !important;
}

/* Chaque carte : pochette en haut (pleine largeur), infos en dessous —
   le titre et l'artiste ont ainsi toute la largeur de la carte pour
   rester lisibles, plutôt que d'être écrasés à côté d'une vignette. */
#rk-played-tracks-widget [class*="track-line"] {
  background: rgba(255,255,255,.07) !important;
  border: 1px solid rgba(255,255,255,.13) !important;
  border-radius: 18px !important;
  padding: 0 !important;
  display: flex !important;
  flex-direction: column !important;
  align-items: stretch !important;
  position: relative !important;
  transition: transform .25s, background .25s !important;
  overflow: hidden !important;
}
#rk-played-tracks-widget [class*="track-line"]:hover {
  transform: translateY(-4px) !important;
  background: rgba(255,255,255,.13) !important;
}

/* ★ Pochette : pleine largeur, carrée ★ */
#rk-played-tracks-widget [class*="played-tracks__image--"] {
  width: 100% !important;
  height: auto !important;
  aspect-ratio: 1 / 1 !important;
  min-width: 0 !important;
  object-fit: cover !important;
  border-radius: 0 !important;
  box-shadow: none !important;
  flex-shrink: 0 !important;
  display: block !important;
}

/* Colonne infos (titre, artiste) — sous la pochette */
#rk-played-tracks-widget [class*="played-tracks__infos--"] {
  min-width: 0 !important;
  padding: .8rem .9rem .9rem !important;
}
#rk-played-tracks-widget [class*="title-block"] {
  min-width: 0 !important;
  overflow: hidden !important;
}

/* Date/heure : en pastille au-dessus de la pochette, pas dans le texte */
#rk-played-tracks-widget [class*="played-tracks__date--"] {
  display: flex !important;
  align-items: center !important;
  gap: .25rem !important;
  position: absolute !important;
  top: .6rem !important;
  right: .6rem !important;
  background: rgba(11,28,45,.65) !important;
  backdrop-filter: blur(4px) !important;
  border-radius: 999px !important;
  padding: .2rem .55rem !important;
  font-size: .64rem !important;
  color: rgba(255,255,255,.85) !important;
  z-index: 2 !important;
}
#rk-played-tracks-widget [class*="played-tracks__date--"] svg {
  width: 9px !important;
  height: 9px !important;
  flex-shrink: 0 !important;
}
#rk-played-tracks-widget [class*="played-tracks__date--"] svg .st0 {
  fill: rgba(255,255,255,.85) !important;
}

/* Titre du morceau — bien visible, sur 2 lignes si besoin */
#rk-played-tracks-widget [class*="played-tracks__title--"] {
  font-weight: 800 !important;
  font-size: 1rem !important;
  line-height: 1.3 !important;
  color: #fff !important;
  display: -webkit-box !important;
  -webkit-line-clamp: 2 !important;
  -webkit-box-orient: vertical !important;
  overflow: hidden !important;
  margin-bottom: .25rem !important;
}

/* Artiste */
#rk-played-tracks-widget [class*="played-tracks__artist--"] {
  font-size: .85rem !important;
  font-weight: 600 !important;
  color: rgba(255,255,255,.75) !important;
  white-space: nowrap !important;
  overflow: hidden !important;
  text-overflow: ellipsis !important;
  display: block !important;
}

/* Premier titre : badge EN COURS, en overlay sur la pochette */
#rk-played-tracks-widget [class*="track-line"]:first-child::after {
  content: '▶ EN COURS' !important;
  position: absolute !important;
  top: .6rem !important;
  left: .6rem !important;
  background: rgba(255,60,172,.85) !important;
  border: 1px solid rgba(255,255,255,.4) !important;
  border-radius: 999px !important;
  padding: .18rem .65rem !important;
  font-size: .62rem !important;
  font-weight: 800 !important;
  letter-spacing: .06em !important;
  color: #fff !important;
  z-index: 2 !important;
}

/* Responsive */
@media (max-width: 900px) {
  #rk-played-tracks-widget #rk-played-tracks-table {
    grid-template-columns: repeat(2,1fr) !important;
  }
}
@media (max-width: 480px) {
  #rk-played-tracks-widget #rk-played-tracks-table {
    grid-template-columns: repeat(2,1fr) !important;
    gap: .6rem !important;
  }
}
</style>



<!-- ============================================================
     COHERENCE CARDIAQUE — bandeau compact
     ============================================================ -->
<section class="ro-section ro-section-alt">
  <div class="container">
    <div class="coherence-banner" style="padding:1.8rem 2rem;display:flex;flex-wrap:wrap;align-items:center;gap:1.5rem;justify-content:space-between;">
      <div style="flex:1;min-width:260px;">
        <span class="section-eyebrow">Exclusivité Radio Odyssey</span>
        <h2 style="margin:.3rem 0 .5rem;">Cohérence Cardiaque <span class="highlight">chaque heure !</span></h2>
        <p style="margin:0;font-size:.92rem;opacity:.92;">
          <i class="bi bi-lungs"></i> Inspirez 5 secondes, expirez 5 secondes, au rythme de la musique — des séquences courtes toute la journée.
        </p>
        <p style="margin:.5rem 0 0;font-size:.82rem;opacity:.85;">
          <i class="bi bi-patch-check-fill" style="color:var(--ro-gold);"></i> Conçues avec <strong>Elisabeth Bélot-Grimaud</strong>, Docteure en psychologie cognitive — <a href="/elisabeth-belot-grimaud-radio-odyssey.html" style="color:inherit;text-decoration:underline;">notre partenaire exclusive</a>.
        </p>
      </div>
      <a href="radio-coherence-cardiaque.html" class="btn-ro" style="flex-shrink:0;">
        <i class="bi bi-arrow-right-circle-fill"></i>&nbsp;En savoir plus
      </a>
    </div>
  </div>
</section>

<!-- ============================================================
     CATÉGORIES — TOUTES NOS PAGES
     ============================================================ -->
<section class="ro-section">
  <div class="container">
