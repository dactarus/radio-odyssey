---
import Icon from '../components/Icon.astro';
import Layout from '../layouts/Layout.astro';
import PageHero from '../components/PageHero.astro';
import Sidebar from '../components/Sidebar.astro';
import FAQBlock from '../components/FAQBlock.astro';
import RelatedPages from '../components/RelatedPages.astro';

const faq = [
  { q: 'Is TuneIn free?', a: "Yes. Listening to Radio Odyssey on TuneIn is completely free, with no account required for basic listening." },
  { q: 'Do I need to create an account?', a: "No — you can search and listen to Radio Odyssey directly. An account is only needed if you want to save favorites within the TuneIn app itself." },
  { q: 'Does it work on car systems and smart speakers?', a: "Yes — TuneIn is built into many car entertainment systems, as well as smart speakers and voice assistants, making it one of the easiest ways to listen to Radio Odyssey while driving or at home." },
];
---
<Layout
  lang="en"
  title="How to Listen to Radio Odyssey on TuneIn | Radio Odyssey"
  description="Step-by-step guide to listening to Radio Odyssey on TuneIn — the easiest way to stream our free positive radio station from anywhere in the world."
>
  <PageHero
    gradientFrom="#1e7fcb"
    gradientTo="#7B2FBE"
    homeLabel="🏠 Home"
    breadcrumbCurrent="How to listen on TuneIn"
    title="How to Listen on TuneIn"
    text="The easiest way to stream Radio Odyssey from anywhere in the world — no account, no cost."
  >
    <Fragment slot="icon">
      <svg viewBox="0 0 48 48" fill="none"><path d="M8 26V24C8 14.6 15.2 7 24 7C32.8 7 40 14.6 40 24V26" stroke="white" stroke-width="2.2" stroke-linecap="round" fill="none"/><rect x="4" y="26" width="8" height="12" rx="3" stroke="white" stroke-width="2.2"/><rect x="36" y="26" width="8" height="12" rx="3" stroke="rgba(255,255,255,.75)" stroke-width="2.2"/></svg>
    </Fragment>
  </PageHero>

  <main class="ro-section">
    <div class="container">
      <div class="row gy-4">
        <div class="col-lg-8">

          <div class="content-card">
            <h2>Why TuneIn</h2>
            <p>TuneIn is one of the most widely used radio platforms in the world — built into countless car entertainment systems, smart speakers and mobile devices. For listeners outside France, it's often the simplest way to find and stream Radio Odyssey.</p>
          </div>

          <div class="content-card">
            <h2>Search and Listen in Seconds</h2>
            <ul>
              <li>Open the TuneIn app or go to <a href="https://tunein.com/radio/RADIO-ODYSSEY-s339104/" target="_blank" rel="noopener" style="color:var(--ro-purple);font-weight:700;">tunein.com</a></li>
              <li>Search for "Radio Odyssey"</li>
              <li>Tap play — no account or sign-up required</li>
            </ul>
          </div>

          <div class="content-card">
            <h2>Also Available on Voice Assistants</h2>
            <p>Simply say:</p>
            <div class="highlight-box" style="font-size:1.1rem;font-family:'Nunito',sans-serif;font-weight:800;color:var(--ro-purple);">
              💬 "Alexa, play Radio Odyssey on TuneIn"
            </div>
          </div>

          <div class="content-card">
            <h2>Other Ways to Listen Internationally</h2>
            <p>Beyond TuneIn, Radio Odyssey is also available on:</p>
            <ul>
              <li><a href="https://www.radioline.co/fr/radios/radio_odyssey" target="_blank" rel="noopener" style="color:var(--ro-purple);">Radio.net</a></li>
              <li><a href="https://mytuner-radio.com/fr/radio/radio-odyssey-512057/" target="_blank" rel="noopener" style="color:var(--ro-purple);">MyTuner Radio</a></li>
              <li><a href="https://streema.com/radios/Radio_Odyssey" target="_blank" rel="noopener" style="color:var(--ro-purple);">Streema</a></li>
              <li><a href="https://www.getmeradio.com/stations/radioodyssey-10965/" target="_blank" rel="noopener" style="color:var(--ro-purple);">Online Radio Box</a></li>
            </ul>
          </div>

          <FAQBlock items={faq} idPrefix="tunein" />

          <RelatedPages
            alsoLike={[
              { href: '/feel-good-music-radio.html', label: 'Feel Good Music Radio', desc: "Radio Odyssey's positive mix" },
              { href: '/80s-throwback-radio-online.html', label: '80s Throwback Radio Online', desc: 'Classic hits, reimagined' },
            ]}
            associated={[
              { href: '/heart-coherence-breathing-radio.html', label: 'Heart Coherence Breathing Radio' },
              { href: '/keep-listening-radio-odyssey.html', label: 'Keep Listening' },
            ]}
          />

          <div class="page-cta-bar">
            <h3>Tune in now</h3>
            <div style="display:flex;flex-wrap:wrap;gap:.8rem;justify-content:center;margin-top:1rem;">
              <a href="https://tunein.com/radio/RADIO-ODYSSEY-s339104/" target="_blank" rel="noopener" class="btn-hero">
                <Icon name="box-arrow-up-right" /> Open on TuneIn
              </a>
              <a href="#" onclick="roPlayNow(event)" class="btn-hero-ghost">
                <Icon name="broadcast-pin" /> Listen Live Here
              </a>
            </div>
          </div>

        </div>
        <div class="col-lg-4">
          <Sidebar />
        </div>
      </div>
    </div>
  </main>
</Layout>
