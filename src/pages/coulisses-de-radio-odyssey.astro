---
import Layout from '../layouts/Layout.astro';
import PageHero from '../components/PageHero.astro';
import Sidebar from '../components/Sidebar.astro';
import CategoryHub from '../components/CategoryHub.astro';
---
<Layout
  lang="fr"
  title="Les Coulisses de Radio Odyssey — Programmation, Jingles & Choix Éditoriaux"
  description="Comment Radio Odyssey construit sa programmation, fabrique ses jingles et fait ses choix éditoriaux : les coulisses de l'antenne, expliquées par l'équipe."
>
  <PageHero
    gradientFrom="#0b1c2d"
    gradientTo="#7B2FBE"
    homeLabel="🏠 Accueil"
    breadcrumbCurrent="Les Coulisses de Radio Odyssey"
    title="Les Coulisses de Radio Odyssey"
    text="Programmation, jingles, choix éditoriaux... la fabrication de l'antenne expliquée par l'équipe de Radio Odyssey."
  >
    <Fragment slot="icon">
      <svg viewBox="0 0 48 48" fill="none"><path d="M24 8L27 14L34 12L33 19L40 22L34 25L36 32L29 30L26 37L24 31L18 36L17 29L10 31L13 24L7 21L14 18L12 11L19 13L22 8L24 8Z" stroke="white" stroke-width="1.8" stroke-linejoin="round" fill="none"/><circle cx="24" cy="21" r="5" stroke="white" stroke-width="2"/></svg>
    </Fragment>
  </PageHero>

  <main class="ro-section">
    <div class="container">
      <div class="row gy-4">
        <div class="col-lg-8">
          <CategoryHub categoryId="coulisses" />
        </div>
        <div class="col-lg-4">
          <Sidebar />
        </div>
      </div>
    </div>
  </main>
</Layout>
