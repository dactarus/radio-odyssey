---
import Layout from '../layouts/Layout.astro';
import PageHero from '../components/PageHero.astro';
import Sidebar from '../components/Sidebar.astro';
import CategoryHub from '../components/CategoryHub.astro';
---
<Layout
  lang="fr"
  title="Musique & Énergie — Toutes les Pages Radio Odyssey"
  description="Années 80, dance énergisante, concentration, radio pour travailler : retrouvez toutes les pages musique & énergie de Radio Odyssey."
>
  <PageHero
    gradientFrom="#FF9A3C"
    gradientTo="#FF3CAC"
    homeLabel="🏠 Accueil"
    breadcrumbCurrent="Musique & Énergie"
    title="Musique & Énergie"
    text="Des années 80 remixées à la dance la plus énergisante — toutes nos pages pour garder le rythme."
  >
    <Fragment slot="icon">
      <svg viewBox="0 0 48 48" fill="none"><circle cx="24" cy="9" r="4" stroke="white" stroke-width="2"/><path d="M24 13 L20 24 L14 22" stroke="white" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" fill="none"/><path d="M24 13 L26 24 L33 20" stroke="rgba(255,255,255,.75)" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" fill="none"/></svg>
    </Fragment>
  </PageHero>

  <main class="ro-section">
    <div class="container">
      <div class="row gy-4">
        <div class="col-lg-8">
          <CategoryHub categoryId="musique-energie" />
        </div>
        <div class="col-lg-4">
          <Sidebar />
        </div>
      </div>
    </div>
  </main>
</Layout>
