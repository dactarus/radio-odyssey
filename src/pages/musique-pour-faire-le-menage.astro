---
import Layout from '../layouts/Layout.astro';
import PageHero from '../components/PageHero.astro';
import Sidebar from '../components/Sidebar.astro';
import FAQBlock from '../components/FAQBlock.astro';
import RelatedPages from '../components/RelatedPages.astro';

const playlistMenage = [
  { slug: 'bruno-mars', name: 'Bruno Mars', track: 'Uptown Funk' },
  { slug: 'queen', name: 'Queen', track: 'We Are The Champions' },
  { slug: 'michael-jackson', name: 'Michael Jackson', track: "Don't Stop 'Til You Get Enough" },
  { slug: 'shakira', name: 'Shakira', track: "Hips Don't Lie (Remix)" },
  { slug: 'david-guetta', name: 'David Guetta', track: 'Titanium (feat. Sia)' },
  { slug: 'dua-lipa', name: 'Dua Lipa', track: "Don't Start Now" },
  { slug: 'lady-gaga', name: 'Lady Gaga', track: 'Bad Romance' },
  { slug: 'sia', name: 'Sia', track: 'Unstoppable' },
];

const faq = [
  { q: 'Est-ce vraiment utile d\'écouter de la musique pour faire le ménage ?', a: "Beaucoup de personnes trouvent que oui : une musique positive et rythmée aide à rendre une tâche répétitive plus agréable, sans exiger d'attention particulière — on peut la suivre ou l'ignorer selon le moment." },
  { q: 'Cette musique convient-elle aussi pour un usage professionnel ?', a: "Oui — agents d'entretien, aides à domicile et professionnels du nettoyage cherchent souvent ce type de flux pour accompagner leurs journées de travail. Radio Odyssey s'y prête bien : continue, gratuite et sans coupure publicitaire." },
  { q: 'Comment l\'écouter les mains prises pendant le ménage ?', a: "Le plus simple est de lancer l'application ou le site sur votre téléphone avant de commencer, posé à proximité ou connecté à une enceinte Bluetooth — pas besoin d'y retoucher ensuite." },
  { q: 'Quelle est la playlist ménage de Radio Odyssey ?', a: "Plutôt qu'une sélection figée, notre playlist ménage reflète les titres réellement les plus diffusés à l'antenne — de Bruno Mars à Dua Lipa en passant par Queen. Elle évolue avec la programmation, mais reste toujours dans cet esprit énergique et fédérateur." },
];
---
<Layout
  lang="fr"
  title="Musique pour Faire le Ménage | Radio Odyssey"
  description="Quelle musique pour faire le ménage ? Découvrez la playlist ménage Radio Odyssey, basée sur les titres réellement diffusés à l'antenne."
>
  <PageHero
    gradientFrom="#00C6FF"
    gradientTo="#FFD700"
    homeLabel="🏠 Accueil"
    breadcrumbCurrent="Musique pour faire le ménage"
    title="Musique pour Faire le Ménage"
    text="Un flux positif et énergisant qui rend les corvées plus légères — à la maison comme au travail."
  >
    <Fragment slot="icon">
      <svg viewBox="0 0 48 48" fill="none"><path d="M28 6L14 34" stroke="white" stroke-width="2.3" stroke-linecap="round"/><path d="M14 34L8 42L11 43L18 37" stroke="white" stroke-width="2.3" stroke-linecap="round" stroke-linejoin="round" fill="none"/><path d="M22 20L34 8" stroke="rgba(255,255,255,.6)" stroke-width="2" stroke-linecap="round"/><path d="M27 25L39 13" stroke="rgba(255,255,255,.6)" stroke-width="2" stroke-linecap="round"/></svg>
    </Fragment>
  </PageHero>

  <main class="ro-section">
    <div class="container">
      <div class="row gy-4">
        <div class="col-lg-8">

          <div class="content-card">
            <h2>Quelle musique pour faire le ménage ?</h2>
            <p>Passer l'aspirateur, ranger, faire la vaisselle : ces tâches répétitives passent beaucoup mieux en musique. Radio Odyssey propose un flux positif et rythmé — dance, hits remixés, énergie continue — qui accompagne le ménage sans jamais devenir monotone.</p>
          </div>

          <div class="content-card">
            <h2>L'avis de notre partenaire psychologue</h2>
            <p>Nous avons posé la question à <strong>Elisabeth Bélot-Grimaud</strong>, Docteure en psychologie cognitive et partenaire exclusive de Radio Odyssey : associer musique et ménage, est-ce une bonne idée ? Sa réponse est claire — cela ne pose aucun souci, bien au contraire. Une musique positive comme celle de Radio Odyssey peut rendre une tâche perçue comme corvée nettement plus plaisante à accomplir.</p>
            <p><a href="/elisabeth-belot-grimaud-radio-odyssey.html" style="color:var(--ro-purple);font-weight:700;">En savoir plus sur notre partenaire <i class="bi bi-arrow-right"></i></a></p>
          </div>

          <div class="content-card">
            <h2>Une vraie recherche, y compris chez les professionnels</h2>
            <p>Ce n'est pas qu'un usage occasionnel du week-end : les agents d'entretien, aides à domicile et professionnels du nettoyage sont nombreux à chercher une radio ou un style de musique énergisant pour accompagner leurs journées de travail. Radio Odyssey répond bien à ce besoin — un flux continu, gratuit et sans coupure publicitaire, qui ne demande aucune attention particulière.</p>
          </div>

          <div class="content-card">
            <h2>Idéale pour…</h2>
            <ul>
              <li>Le grand ménage du week-end</li>
              <li>Les tâches ménagères du quotidien</li>
              <li>Un usage professionnel (agents d'entretien, aide à domicile)</li>
              <li>Ranger, plier, nettoyer — tout ce qui se fait "les mains occupées"</li>
            </ul>
            <p>Une énergie continue et positive, du début à la fin de la tâche.</p>
          </div>

          <div class="content-card">
            <h2>Notre playlist ménage : la vraie programmation de l'antenne</h2>
            <p>Beaucoup de sites proposent une "playlist spéciale ménage" toujours composée des mêmes classiques piochés au hasard sur le web. Chez Radio Odyssey, on a préféré une autre approche : voici les titres qui reviennent le plus souvent, réellement, sur notre antenne — un aperçu direct de la programmation plutôt qu'une liste générique.</p>
            <div style="display:flex;flex-direction:column;gap:.7rem;">
              {playlistMenage.map((a, i) => (
                <a href={`/artiste-${a.slug}.html`} style="display:flex;justify-content:space-between;align-items:center;gap:1rem;text-decoration:none;color:var(--ro-dark);padding:.7rem .9rem;border-radius:12px;background:rgba(123,47,190,.04);">
                  <span style="display:flex;align-items:center;gap:.8rem;">
                    <span style="font-weight:900;color:var(--ro-purple);font-size:1.1rem;min-width:1.6rem;">{i + 1}</span>
                    <span>
                      <strong style="color:var(--ro-purple);">{a.name}</strong><br/>
                      <span style="font-size:.82rem;color:var(--ro-muted);">{a.track}</span>
                    </span>
                  </span>
                  <i class="bi bi-arrow-right" style="color:var(--ro-purple);flex-shrink:0;"></i>
                </a>
              ))}
            </div>
            <p style="margin-top:1rem;">Envie d'aller plus loin ? Découvrez <a href="/artistes-diffuses-radio-odyssey.html" style="color:var(--ro-purple);font-weight:700;">tous les artistes diffusés sur Radio Odyssey</a> et leurs titres les plus joués.</p>
          </div>

          <FAQBlock items={faq} idPrefix="menage" />

          <RelatedPages
            alsoLike={[
              { href: '/musique-odyssey-pour-aller-mieux.html', label: "La Musique d'Odyssey pour Aller Mieux", desc: "L'angle positif de notre programmation" },
              { href: '/musique-pour-faire-du-sport.html', label: 'Musique pour Faire du Sport', desc: 'Le flux énergisant pour vos séances' },
              { href: '/artistes-diffuses-radio-odyssey.html', label: 'Tous les Artistes Diffusés', desc: 'Le classement complet, tous styles confondus' },
            ]}
            associated={[
              { href: '/radio-sans-publicite.html', label: 'Radio sans publicité' },
              { href: '/elisabeth-belot-grimaud-radio-odyssey.html', label: 'Notre partenaire Elisabeth Bélot-Grimaud' },
              { href: '/ecouter-radio-odyssey-sur-mobile.html', label: 'Écouter sur mobile' },
            ]}
          />

          <div class="page-cta-bar">
            <h3>Lancez la musique, le ménage suivra</h3>
            <div style="display:flex;flex-wrap:wrap;gap:.8rem;justify-content:center;margin-top:1rem;">
              <a href="#" onclick="roPlayNow(event)" class="btn-hero">
                <i class="bi bi-broadcast-pin"></i> Écouter en Direct
              </a>
              <a href="https://app.radio-odyssey.com/" target="_blank" rel="noopener" class="btn-hero-ghost">
                <i class="bi bi-phone"></i> Télécharger l'application
              </a>
            </div>
          </div>

        </div>
        <div class="col-lg-4">
          <Sidebar />
        </div>
      </div>
    </div>
  </main>
</Layout>
