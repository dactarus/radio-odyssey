---
import Icon from '../components/Icon.astro';
import Layout from '../layouts/Layout.astro';
import PageHero from '../components/PageHero.astro';
import Sidebar from '../components/Sidebar.astro';
import FAQBlock from '../components/FAQBlock.astro';
import RelatedPages from '../components/RelatedPages.astro';
import ContentIllustration from '../components/ContentIllustration.astro';

const faq = [
  { q: 'Radio Odyssey est-elle vraiment 100% gratuite ?', a: "Oui. L'écoute en direct est gratuite, sans création de compte et sans limite de temps, sur tous les supports (web, mobile, voiture, enceinte connectée)." },
  { q: 'Y a-t-il des coupures publicitaires sur le flux musical ?', a: "Non, le flux ne contient aucune publicité — ni audio, ni pop-up. La seule interruption au fil de la journée, ce sont les séquences de cohérence cardiaque, intégrées volontairement à la programmation." },
  { q: 'Comment Radio Odyssey se finance sans publicité ?', a: "Grâce au soutien de son partenaire exclusif, Elisabeth Bélot-Grimaud, Docteure en psychologie cognitive, présentée sur la page d'accueil." },
  { q: 'Faut-il créer un compte pour écouter ?', a: "Non, aucune inscription n'est nécessaire. Un clic sur \"Écouter en direct\" suffit." },
  { q: "Existe-t-il une version payante avec plus de fonctionnalités ?", a: "Non, il n'existe qu'une seule version de Radio Odyssey, et elle est gratuite pour tous les auditeurs." },
];
---
<Layout
  lang="fr"
  title="Radio Odyssey — Une Web Radio 100% Gratuite, Sans Publicité"
  description="Aucune coupure publicitaire, aucun abonnement, aucun compte à créer : découvrez pourquoi et comment Radio Odyssey reste gratuite et sans pub."
>
  <PageHero
    gradientFrom="#FFD700"
    gradientTo="#FF9A3C"
    homeLabel="🏠 Accueil"
    breadcrumbCurrent="Radio sans publicité"
    title="Radio Sans Publicité"
    text="Aucune coupure, aucun abonnement, aucun compte à créer — juste de la musique, gratuitement."
  >
    <Fragment slot="icon">
      <svg viewBox="0 0 48 48" fill="none"><circle cx="24" cy="24" r="18" stroke="white" stroke-width="2.5"/><path d="M16 16L32 32M32 16L16 32" stroke="white" stroke-width="2.5" stroke-linecap="round"/></svg>
    </Fragment>
  </PageHero>

  <main class="ro-section">
    <div class="container">
      <div class="row gy-4">
        <div class="col-lg-8">

          <div class="content-card">
            <h2>Pourquoi Radio Odyssey ne diffuse aucune publicité</h2>
            <p>La plupart des radios en ligne financent leur diffusion par des coupures publicitaires régulières, parfois toutes les 15 à 20 minutes. Radio Odyssey a fait un choix différent dès son lancement en janvier 2025 : diffuser une programmation continue, sans aucune interruption commerciale, du premier au dernier morceau de la journée.</p>
          </div>

          <div class="content-card">
            <h2>Ce que ça change concrètement pour vous</h2>
            <h3>Une écoute sans interruption</h3>
            <p>Le flux musical ne s'arrête jamais pour une publicité. La seule "pause" prévue dans la programmation, ce sont les séquences de <a href="/radio-coherence-cardiaque.html" style="color:var(--ro-purple);font-weight:700;">cohérence cardiaque</a>, intégrées volontairement — pas imposées par un annonceur.</p>
            <h3>Pas d'abonnement caché</h3>
            <p>Il n'existe pas de version "premium sans pub" à débloquer : l'expérience gratuite est déjà, par défaut, sans aucune publicité.</p>
            <h3>Un modèle différent des radios commerciales</h3>
            <p>Contrairement à une radio FM classique qui vit de ses annonceurs, Radio Odyssey s'appuie sur le soutien de partenaires en phase avec son positionnement bien-être.</p>
          </div>

          <div class="content-card">
            <h2>Comment Radio Odyssey se finance sans publicité</h2>
            <h3>Le soutien des partenaires</h3>
            <p>Radio Odyssey est notamment soutenue par <a href="/elisabeth-belot-grimaud-radio-odyssey.html" style="color:var(--ro-purple);font-weight:700;">Elisabeth Bélot-Grimaud</a>, Docteure en psychologie cognitive et partenaire exclusive de la radio — un partenariat cohérent avec l'esprit bien-être de la radio plutôt qu'une régie publicitaire classique.</p>
            <h3>Aucun coût pour l'auditeur</h3>
            <p>Ce modèle permet de garder l'écoute entièrement gratuite pour chaque auditeur, sans contrepartie financière ni publicitaire demandée.</p>
          </div>

          <ContentIllustration gradientFrom="#FFD700" gradientTo="#FF9A3C" caption="Aucune coupure, aucune interruption — juste la musique.">
            <Fragment slot="icon">
              <svg viewBox="0 0 48 48" fill="none"><circle cx="24" cy="24" r="18" stroke="white" stroke-width="2.5"/><path d="M16 16L32 32M32 16L16 32" stroke="white" stroke-width="2.5" stroke-linecap="round"/></svg>
            </Fragment>
          </ContentIllustration>

          <div class="content-card">
            <h2>Comparé aux autres façons d'écouter de la musique en ligne</h2>
            <h3>Les radios FM en streaming</h3>
            <p>La plupart des radios FM qui diffusent aussi en ligne conservent leurs coupures publicitaires habituelles sur le flux web.</p>
            <h3>Les plateformes avec abonnement premium</h3>
            <p>Certaines plateformes de streaming proposent une écoute sans pub, mais uniquement via un abonnement payant mensuel. Radio Odyssey ne propose qu'une seule offre : gratuite, et déjà sans publicité.</p>
          </div>

          <div class="content-card">
            <h2>Comment profiter de cette écoute sans publicité</h2>
            <h3>Sur le web</h3>
            <p>Un clic sur "Écouter en direct" en haut de n'importe quelle page du site suffit à démarrer le flux, sans publicité ni inscription.</p>
            <h3>Sur mobile et enceinte connectée</h3>
            <p>La même expérience sans pub est disponible via l'<a href="/ecouter-radio-odyssey-sur-mobile.html" style="color:var(--ro-purple);font-weight:700;">application mobile</a>, en <a href="/ecouter-radio-odyssey-en-voiture.html" style="color:var(--ro-purple);font-weight:700;">voiture</a> ou sur une <a href="/ecouter-radio-odyssey-enceinte-connectee.html" style="color:var(--ro-purple);font-weight:700;">enceinte connectée</a>.</p>
            <h3>Sur les plateformes partenaires</h3>
            <p>Le même flux sans publicité est aussi accessible via TuneIn, Deezer ou WeLoveRadio — le contenu diffusé reste identique, sans coupure commerciale ajoutée.</p>
          </div>

          <FAQBlock items={faq} idPrefix="rsp" />

          <RelatedPages
            alsoLike={[
              { href: '/bien-etre-et-sante.html', label: 'Le cocon Bien-être', desc: 'Toutes nos pages bien-être' },
              { href: '/avis-radio-odyssey-bien-etre.html', label: 'Avis sur Radio Odyssey', desc: 'Ce que les auditeurs en disent' },
            ]}
            associated={[
              { href: '/ecouter-radio-odyssey-sur-mobile.html', label: 'Écouter sur mobile' },
              { href: '/conseils-ecoute.html', label: 'Tous nos conseils d\'écoute' },
              { href: '/', label: "Page d'accueil" },
            ]}
          />

          <div class="page-cta-bar">
            <h3>Écoutez, gratuitement, sans pub</h3>
            <div style="display:flex;flex-wrap:wrap;gap:.8rem;justify-content:center;margin-top:1rem;">
              <a href="#" onclick="roPlayNow(event)" class="btn-hero">
                <Icon name="broadcast-pin" /> Écouter Radio Odyssey
              </a>
              <a href="https://app.radio-odyssey.com/" target="_blank" rel="noopener" class="btn-hero-ghost">
                <Icon name="phone" /> Télécharger l'application
              </a>
              <a href="/bien-etre-et-sante.html" class="btn-hero-ghost">
                <Icon name="grid" /> Découvrir les autres thèmes
              </a>
            </div>
          </div>

        </div>
        <div class="col-lg-4">
          <Sidebar />
        </div>
      </div>
    </div>
  </main>
</Layout>
