---
import Layout from '../layouts/Layout.astro';
import PageHero from '../components/PageHero.astro';
import Sidebar from '../components/Sidebar.astro';
---
<Layout lang="en" title="Radio Odyssey, positive european music station – Radio Odyssey" description="Listen to Radio Odyssey – The best positive European music station: 80s hits, dance classics, remix, synthwave and feel-good music worldwide.">
  <PageHero
    gradientFrom="#1e7fcb"
    gradientTo="#0b1c2d"
    homeLabel="🏠 Home"
    breadcrumbCurrent="Radio Odyssey, positive european music station"
    title="Positive European Music Station"
    text="Listen to Radio Odyssey — The Best European 80s, Remix & Feel-Good Music, streaming worldwide 24/7."
  >
    <Fragment slot="icon">
      <svg viewBox="0 0 48 48" fill="none"><circle cx="24" cy="24" r="18" stroke="white" stroke-width="2.5"/><ellipse cx="24" cy="24" rx="7" ry="18" stroke="rgba(255,255,255,.65)" stroke-width="2"/><line x1="6" y1="17" x2="42" y2="17" stroke="rgba(255,255,255,.5)" stroke-width="1.8"/><line x1="6" y1="31" x2="42" y2="31" stroke="rgba(255,255,255,.5)" stroke-width="1.8"/></svg>
    </Fragment>
  </PageHero>

  <main class="ro-section">
    <div class="container">
      <div class="row gy-4">
        <div class="col-lg-8">
        
          <div class="content-card">
            <h2>Welcome to Radio Odyssey</h2>
            <p>Your positive European music station broadcasting the best mix of 80s hits, dance classics, remix tracks, synthwave vibes and uplifting music from France to the world.</p>
            <div class="highlight-box">
              <a href="#" onclick="roPlayNow(event)" class="btn-ro">
                <i class="bi bi-broadcast-pin"></i>&nbsp;&#9654; Listen Live Now
              </a>
            </div>
          </div>

          <div class="content-card">
            <h2>Why Listeners in the USA Love Radio Odyssey</h2>
            <p>Radio Odyssey delivers a unique European radio experience with carefully selected music, positive energy and non-stop feel-good vibes.</p>
            <ul>
              <li>&#10004; Best 80s remix radio station</li>
              <li>&#10004; European dance classics</li>
              <li>&#10004; Positive and uplifting music</li>
              <li>&#10004; French web radio available worldwide</li>
              <li>&#10004; Synthwave, retro pop and chill vibes</li>
              <li>&#10004; Perfect soundtrack for work, driving and relaxing</li>
            </ul>
          </div>

          <div class="content-card">
            <h2>Available Everywhere</h2>
            <p>You can listen to Radio Odyssey worldwide on&#160;:</p>
            <ul>
              <li><a href="https://tunein.com/radio/RADIO-ODYSSEY-s339104/" target="_blank" rel="noopener" style="color:var(--ro-purple);">TuneIn</a></li>
              <li><a href="https://mytuner-radio.com/fr/radio/radio-odyssey-512057/" target="_blank" rel="noopener" style="color:var(--ro-purple);">myTuner Radio</a></li>
              <li><a href="https://www.radioline.co/fr/radios/radio_odyssey" target="_blank" rel="noopener" style="color:var(--ro-purple);">Radio.net</a></li>
              <li><a href="https://streema.com/radios/Radio_Odyssey" target="_blank" rel="noopener" style="color:var(--ro-purple);">Simple Radio / Streema</a></li>
              <li><a href="https://www.getmeradio.com/stations/radioodyssey-10965/" target="_blank" rel="noopener" style="color:var(--ro-purple);">Online Radio Box</a></li>
              <li>Smartphones, tablets and connected speakers</li>
              <li>CarPlay and Android Auto</li>
            </ul>
          </div>

          <div class="content-card">
            <h2>The Sound of Positive Europe</h2>
            <p>Based in France, Radio Odyssey connects listeners across Europe and the United States with a fresh mix of nostalgic classics and modern remix culture.</p>
            <p>Whether you love 80s music, euro dance, chill electronic vibes or uplifting radio, Radio Odyssey brings positive energy 24/7.</p>
          </div>

          <div class="content-card">
            <h2>Explore Radio Odyssey</h2>
            <ul>
              <li><a href="index.html" style="color:var(--ro-purple);">Home Page</a></li>
              <li><a href="positive-european-music-station.html" style="color:var(--ro-purple);">Positive European Music Station</a></li>
              <li><a href="european-chill-radio.html" style="color:var(--ro-purple);">European Chill Radio</a></li>
              <li><a href="feel-good-music-radio.html" style="color:var(--ro-purple);">Feel Good Music Radio</a></li>
              <li><a href="keep-listening-radio-odyssey.html" style="color:var(--ro-purple);">Keep Listening</a></li>
            </ul>
          </div>

          <div class="page-cta-bar">
            <h3>Stream Radio Odyssey Live Anytime</h3>
            <a href="#" onclick="roPlayNow(event)" class="btn-hero">
              <i class="bi bi-broadcast-pin"></i> Start Listening
            </a>
          </div>
        </div>
        <div class="col-lg-4">
          <Sidebar />
        </div>
      </div>
    </div>
  </main>
</Layout>
