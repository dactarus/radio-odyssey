---
import Layout from '../layouts/Layout.astro';
import PageHero from '../components/PageHero.astro';
import Sidebar from '../components/Sidebar.astro';
import CategoryHub from '../components/CategoryHub.astro';
---
<Layout
  lang="fr"
  title="Artistes & Styles Musicaux — Radio Odyssey"
  description="Découvrez qui passe sur l'antenne de Radio Odyssey et dans quels styles musicaux — artistes diffusés et grandes familles de genres."
  ogImage="/assets/images/og/artistes.jpg"
>
  <PageHero
    gradientFrom="#FFD700"
    gradientTo="#7B2FBE"
    homeLabel="🏠 Accueil"
    breadcrumbCurrent="Artistes & Styles"
    title="Artistes & Styles Musicaux"
    text="Qui passe sur l'antenne, et dans quels styles — découvrez les artistes et les familles musicales de Radio Odyssey."
  >
    <Fragment slot="icon">
      <svg viewBox="0 0 48 48" fill="none"><circle cx="20" cy="26" r="15" stroke="white" stroke-width="2.5"/><circle cx="20" cy="26" r="5" stroke="white" stroke-width="2"/><circle cx="20" cy="26" r="1.3" fill="white"/><path d="M28 14L38 10V22L28 26Z" stroke="white" stroke-width="1.8" stroke-linejoin="round" fill="none"/></svg>
    </Fragment>
  </PageHero>

  <main class="ro-section">
    <div class="container">
      <div class="row gy-4">
        <div class="col-lg-8">
          <CategoryHub categoryId="artistes-styles" />
        </div>
        <div class="col-lg-4">
          <Sidebar />
        </div>
      </div>
    </div>
  </main>
</Layout>
