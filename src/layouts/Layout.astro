---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import CookieConsent from '../components/CookieConsent.astro';

interface Props {
  lang?: 'fr' | 'en';
  title: string;
  description: string;
  ogTitle?: string;
  ogDescription?: string;
  ogType?: string;
  ogImage?: string;
  robots?: string;
}

const {
  lang = 'fr',
  title,
  description,
  ogTitle = title,
  ogDescription = description,
  ogType = 'website',
  ogImage = '/assets/images/og/home.jpg',
  robots = 'index, follow',
} = Astro.props;

const ogImageURL = new URL(ogImage, Astro.site);

const canonicalPath = Astro.url.pathname === '/index.html' ? '/' : Astro.url.pathname;
const canonicalURL = new URL(canonicalPath, Astro.site);

const organizationSchema = {
  '@context': 'https://schema.org',
  '@type': 'RadioStation',
  name: 'Radio Odyssey',
  alternateName: 'La Positive Radio',
  url: 'https://www.radio-odyssey.com',
  logo: 'https://www.radio-odyssey.com/assets/images/logo.png',
  sameAs: [
    'https://www.facebook.com/profile.php?id=61588289230589',
    'https://www.instagram.com/radio_odyssey_france/',
    'https://x.com/Odysseylaradio',
    'https://www.youtube.com/channel/UCodzZ_dhFdJwQ90nZzVHluw',
  ],
};

// BreadcrumbList : dérivé du <title> (déjà unique par page), pas besoin
// de faire passer un prop supplémentaire à chaque page. La page d'accueil
// n'a pas de fil d'Ariane propre (c'est la racine), donc pas de schema ici.
const isHome = canonicalPath === '/';
const breadcrumbLabel = title.replace(/\s*[|—]\s*Radio Odyssey\s*$/i, '').trim();
const breadcrumbSchema = isHome ? null : {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Accueil', item: new URL('/', Astro.site).toString() },
    { '@type': 'ListItem', position: 2, name: breadcrumbLabel || title, item: canonicalURL.toString() },
  ],
};
---
<!DOCTYPE html>
<html lang={lang}>
<head>
  <meta charset="UTF-8"/>
  <link rel="icon" type="image/png" sizes="32x32" href="/assets/images/favicon-32.png"/>
  <link rel="icon" type="image/png" sizes="48x48" href="/assets/images/favicon-48.png"/>
  <link rel="icon" type="image/png" href="/assets/images/logo.png"/>
  <link rel="apple-touch-icon" href="/assets/images/logo.png"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>{title}</title>
  <meta name="description" content={description}/>
  <meta name="robots" content={robots}/>
  <link rel="canonical" href={canonicalURL}/>
  <link rel="alternate" hreflang={lang} href={canonicalURL}/>
  <link rel="alternate" hreflang="x-default" href={new URL('/', Astro.site)}/>
  <meta property="og:title" content={ogTitle}/>
  <meta property="og:description" content={ogDescription}/>
  <meta property="og:image" content={ogImageURL}/>
  <meta property="og:image:width" content="1200"/>
  <meta property="og:image:height" content="630"/>
  <meta property="og:type" content={ogType}/>
  <meta property="og:url" content={canonicalURL}/>
  <meta name="twitter:card" content="summary_large_image"/>
  <meta name="twitter:title" content={ogTitle}/>
  <meta name="twitter:description" content={ogDescription}/>
  <meta name="twitter:image" content={ogImageURL}/>

  <link rel="preload" href="/assets/fonts/nunito-latin.woff2" as="font" type="font/woff2" crossorigin/>
  <link rel="preload" href="/assets/fonts/inter-latin.woff2" as="font" type="font/woff2" crossorigin/>
  <link rel="stylesheet" href="/assets/css/fonts.css"/>
  <link rel="stylesheet" href="/assets/vendor/bootstrap/bootstrap.min.css"/>
  <link rel="stylesheet" href="/assets/vendor/bootstrap-icons/bootstrap-icons.min.css"/>
  <link rel="stylesheet" href="/assets/css/style.css"/>

  <script type="application/ld+json" is:inline set:html={JSON.stringify(organizationSchema)} />
  {breadcrumbSchema && (
    <script type="application/ld+json" is:inline set:html={JSON.stringify(breadcrumbSchema)} />
  )}

  <slot name="head" />
</head>
<body>
  <Header />
  <slot />
  <Footer />
  <CookieConsent />
</body>
</html>
