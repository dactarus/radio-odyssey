---
import { ClientRouter } from 'astro:transitions';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import CookieConsent from '../components/CookieConsent.astro';
import WebviewBanner from '../components/WebviewBanner.astro';

interface Props {
  lang?: 'fr' | 'en';
  title: string;
  description: string;
  ogTitle?: string;
  ogDescription?: string;
  ogType?: string;
  ogImage?: string;
  robots?: string;
  articleDatePublished?: string;
  articleAuthorName?: string;
}

const {
  lang = 'fr',
  title,
  description,
  ogTitle = title,
  ogDescription = description,
  ogType = 'website',
  ogImage = '/assets/images/og/home.jpg',
  robots = 'index, follow',
  articleDatePublished,
  articleAuthorName,
} = Astro.props;

const ogImageURL = new URL(ogImage, Astro.site);

const canonicalPath = Astro.url.pathname === '/index.html' ? '/' : Astro.url.pathname;
const canonicalURL = new URL(canonicalPath, Astro.site);

// Trois entités distinctes, reliées par @id : l'association (Organization,
// l'éditeur légal), le site web (WebSite, la publication numérique) et la
// station (RadioStation, la marque antenne). RadioStation.publisher et
// WebSite.publisher pointent tous les deux vers l'Organization plutôt que
// de dupliquer ses informations.
const associationSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  '@id': 'https://www.radio-odyssey.com/#organization',
  name: 'Radio Odyssey',
  legalName: 'Radio Odyssey',
  description: "Association loi 1901 à but non lucratif, éditrice de la web radio Radio Odyssey.",
  url: 'https://www.radio-odyssey.com',
  logo: {
    '@type': 'ImageObject',
    url: 'https://www.radio-odyssey.com/assets/images/logo.png',
    width: 512,
    height: 512,
  },
  email: 'odysseylaradio@gmail.com',
  address: {
    '@type': 'PostalAddress',
    addressCountry: 'FR',
  },
};

const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  '@id': 'https://www.radio-odyssey.com/#website',
  name: 'Radio Odyssey',
  url: 'https://www.radio-odyssey.com',
  inLanguage: 'fr',
  publisher: { '@id': 'https://www.radio-odyssey.com/#organization' },
};

const organizationSchema = {
  '@context': 'https://schema.org',
  '@type': 'RadioStation',
  '@id': 'https://www.radio-odyssey.com/#radiostation',
  name: 'Radio Odyssey',
  alternateName: 'La Positive Radio',
  slogan: 'La Positive Radio',
  description: "Radio Odyssey est une web radio associative française, gratuite et sans publicité, qui allie musique et bien-être : elle diffuse 24h/24 un mélange de hits des années 80 revisités, de dance énergisante et de nouveautés, avec des séquences de cohérence cardiaque intégrées à l'antenne pour accompagner la détente et la respiration de ses auditeurs.",
  keywords: 'radio bien-être, cohérence cardiaque, radio positive, musique et bien-être, web radio gratuite',
  knowsAbout: ['Musique positive', 'Cohérence cardiaque', 'Bien-être', 'Radio musicale', 'Easy listening', 'Années 80'],
  inLanguage: 'fr',
  foundingDate: '2025-01-19',
  areaServed: {
    '@type': 'Country',
    name: 'France',
  },
  url: 'https://www.radio-odyssey.com',
  publisher: { '@id': 'https://www.radio-odyssey.com/#organization' },
  logo: {
    '@type': 'ImageObject',
    url: 'https://www.radio-odyssey.com/assets/images/logo.png',
    width: 512,
    height: 512,
  },
  image: 'https://www.radio-odyssey.com/assets/images/og/home.jpg',
  address: {
    '@type': 'PostalAddress',
    addressCountry: 'FR',
  },
  contactPoint: {
    '@type': 'ContactPoint',
    email: 'odysseylaradio@gmail.com',
    contactType: 'customer support',
  },
  potentialAction: {
    '@type': 'ListenAction',
    target: {
      '@type': 'EntryPoint',
      urlTemplate: 'https://play.radioking.io/radio-odyssey',
      actionPlatform: [
        'https://schema.org/DesktopWebPlatform',
        'https://schema.org/MobileWebPlatform',
        'https://schema.org/IOSPlatform',
        'https://schema.org/AndroidPlatform',
      ],
    },
    expectsAcceptanceOf: {
      '@type': 'Offer',
      price: '0',
      priceCurrency: 'EUR',
      availability: 'https://schema.org/InStock',
    },
  },
  sameAs: [
    'https://www.facebook.com/profile.php?id=61588289230589',
    'https://www.instagram.com/radio_odyssey_france/',
    'https://x.com/Odysseylaradio',
    'https://www.youtube.com/channel/UCodzZ_dhFdJwQ90nZzVHluw',
    'https://tunein.com/radio/RADIO-ODYSSEY-s339104/',
    'https://link.radioking.com/radio-odyssey',
  ],
};

// BreadcrumbList : dérivé du <title> (déjà unique par page), pas besoin
// de faire passer un prop supplémentaire à chaque page. La page d'accueil
// n'a pas de fil d'Ariane propre (c'est la racine), donc pas de schema ici.
const isHome = canonicalPath === '/';
const breadcrumbLabel = title.replace(/\s*[|—]\s*Radio Odyssey\s*$/i, '').trim();
const breadcrumbSchema = isHome ? null : {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Accueil', item: new URL('/', Astro.site).toString() },
    { '@type': 'ListItem', position: 2, name: breadcrumbLabel || title, item: canonicalURL.toString() },
  ],
};

// Article schema : uniquement sur les pages qui passent articleDatePublished
// (les articles éditoriaux type "Coulisses"), pas sur les pages produit/hub.
const articleSchema = articleDatePublished ? {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: breadcrumbLabel || title,
  description,
  datePublished: articleDatePublished,
  dateModified: articleDatePublished,
  author: articleAuthorName
    ? { '@type': 'Person', name: articleAuthorName }
    : { '@type': 'Organization', name: 'Radio Odyssey' },
  publisher: { '@type': 'Organization', name: 'Radio Odyssey', logo: { '@type': 'ImageObject', url: 'https://www.radio-odyssey.com/assets/images/logo.png' } },
  image: ogImageURL.toString(),
  mainEntityOfPage: canonicalURL.toString(),
} : null;
---
<!DOCTYPE html>
<html lang={lang}>
<head>
  <meta charset="UTF-8"/>
  <link rel="icon" type="image/png" sizes="32x32" href="/assets/images/favicon-32.png"/>
  <link rel="icon" type="image/png" sizes="48x48" href="/assets/images/favicon-48.png"/>
  <link rel="icon" type="image/png" href="/assets/images/logo.png"/>
  <link rel="apple-touch-icon" href="/assets/images/icon-192.png"/>
  <link rel="manifest" href="/manifest.json"/>
  <meta name="theme-color" content="#7B2FBE"/>
  <meta name="apple-mobile-web-app-capable" content="yes"/>
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent"/>
  <meta name="apple-mobile-web-app-title" content="Radio Odyssey"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>{title}</title>
  <meta name="description" content={description}/>
  <meta name="robots" content={robots}/>
  <link rel="canonical" href={canonicalURL}/>
  <link rel="alternate" hreflang={lang} href={canonicalURL}/>
  <link rel="alternate" hreflang="x-default" href={new URL('/', Astro.site)}/>
  <meta property="og:title" content={ogTitle}/>
  <meta property="og:description" content={ogDescription}/>
  <meta property="og:image" content={ogImageURL}/>
  <meta property="og:image:width" content="1200"/>
  <meta property="og:image:height" content="630"/>
  <meta property="og:type" content={ogType}/>
  <meta property="og:url" content={canonicalURL}/>
  <meta name="twitter:card" content="summary_large_image"/>
  <meta name="twitter:title" content={ogTitle}/>
  <meta name="twitter:description" content={ogDescription}/>
  <meta name="twitter:image" content={ogImageURL}/>

  <link rel="preload" href="/assets/fonts/nunito-latin.woff2" as="font" type="font/woff2" crossorigin/>
  <link rel="preload" href="/assets/fonts/inter-latin.woff2" as="font" type="font/woff2" crossorigin/>
  <!-- ?v=... : incrémenter à chaque modification de fonts.css/style.css.
       Ces fichiers sont modifiés en place (pas de renommage) ; le paramètre
       force un nouveau cache (navigateur + CDN Vercel) à chaque changement,
       au lieu de compter sur l'expiration du cache existant. -->
  <link rel="stylesheet" href="/assets/css/fonts.css?v=20260717b"/>
  <link rel="stylesheet" href="/assets/vendor/bootstrap/bootstrap.min.css"/>
  <link rel="stylesheet" href="/assets/css/style.css?v=20260717c"/>

  <!-- Umami : mesure d'audience sans cookie, pas de bandeau de consentement requis -->
  <script defer src="https://eu.umami.is/script.js" data-website-id="93f685e2-de60-4635-855a-b07be4902808"></script>

  <!-- Navigation client-side : garde le lecteur RadioKing (#topRadioBar,
       transition:persist) en lecture continue quand on change de page. -->
  <ClientRouter />

  <script type="application/ld+json" is:inline set:html={JSON.stringify(associationSchema)} />
  <script type="application/ld+json" is:inline set:html={JSON.stringify(websiteSchema)} />
  <script type="application/ld+json" is:inline set:html={JSON.stringify(organizationSchema)} />
  {breadcrumbSchema && (
    <script type="application/ld+json" is:inline set:html={JSON.stringify(breadcrumbSchema)} />
  )}
  {articleSchema && (
    <script type="application/ld+json" is:inline set:html={JSON.stringify(articleSchema)} />
  )}

  <slot name="head" />
</head>
<body>
  <Header />
  <WebviewBanner />
  <slot />
  <Footer />
  <CookieConsent />
</body>
</html>
