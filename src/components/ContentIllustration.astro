---
// Bloc décoratif pour aérer les pages longues — même langage graphique
// que le hero et les images de partage social (dégradé de marque,
// bulles, badge icône), sans photo. Réutilise l'icône/dégradé déjà
// définis pour le hero de la page, passés en props.
interface Props {
  gradientFrom: string;
  gradientTo: string;
  caption?: string;
}
const { gradientFrom, gradientTo, caption } = Astro.props;
---
<div class="content-illustration" style={`background:linear-gradient(135deg,${gradientFrom},${gradientTo})`}>
  <div class="ci-bubble ci-b1"></div>
  <div class="ci-bubble ci-b2"></div>
  <div class="ci-bubble ci-b3"></div>
  <div class="ci-icon"><slot name="icon" /></div>
  {caption && <p class="ci-caption">{caption}</p>}
</div>

<style>
  .content-illustration {
    position: relative;
    border-radius: 24px;
    padding: 2.4rem 2rem;
    margin: 0 0 1.5rem;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    min-height: 150px;
    text-align: center;
  }
  .ci-bubble { position: absolute; border-radius: 50%; background: rgba(255,255,255,.1); pointer-events: none; }
  .ci-b1 { width: 220px; height: 220px; top: -90px; right: -60px; }
  .ci-b2 { width: 140px; height: 140px; bottom: -70px; left: -30px; background: rgba(255,255,255,.07); }
  .ci-b3 { width: 80px; height: 80px; top: 10px; left: 18%; background: rgba(255,255,255,.06); }
  .ci-icon {
    width: 78px; height: 78px; border-radius: 50%;
    background: rgba(255,255,255,.18); border: 2px solid rgba(255,255,255,.35);
    display: flex; align-items: center; justify-content: center;
    z-index: 2; margin-bottom: .7rem; flex-shrink: 0;
  }
  .ci-icon svg { width: 42px; height: 42px; }
  .ci-caption {
    color: #fff; font-family: 'Nunito', sans-serif; font-weight: 800;
    font-size: 1.05rem; z-index: 2; margin: 0; max-width: 480px;
    text-shadow: 0 2px 10px rgba(0,0,0,.2); line-height: 1.4;
  }
</style>
