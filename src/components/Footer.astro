---
import Icon from './Icon.astro';
import { NAV_CATEGORIES } from '../data/navigation.js';
const FOOTER_PAGE_LIMIT = 4;
---
<!-- FOOTER -->
<footer id="site-footer">
  <div class="container">
    <div class="row gy-4">
      <div class="col-lg-4">
        <div class="footer-logo-wrap">
          <picture>
            <source srcset="/assets/images/logo.webp" type="image/webp"/>
            <img src="/assets/images/logo.png" alt="Radio Odyssey" width="512" height="512"/>
          </picture>
          <div class="footer-brand">Radio Odyssey<small>Positive Web Radio ✨</small></div>
        </div>
        <p style="font-size:.85rem;max-width:280px;">La webradio positive française — Hits des années 80, dance, easy listening et bien-être, 24h/24, gratuitement, depuis janvier 2025 !</p>
        <a href="mailto:odysseylaradio@gmail.com" style="color:var(--ro-sky)!important;">odysseylaradio@gmail.com</a>
      </div>
      {NAV_CATEGORIES.map((cat) => (
        <div class="col-sm-6 col-lg-2">
          <h5>{cat.label}</h5>
          {cat.pages.slice(0, FOOTER_PAGE_LIMIT).map((p) => (
            <a href={p.href}>{p.label}</a>
          ))}
          {cat.pages.length > FOOTER_PAGE_LIMIT && (
            <a href={cat.hub} style="font-weight:700;">Voir tout →</a>
          )}
        </div>
      ))}
      <div class="col-sm-6 col-lg-2">
        <h5>Écouter sur</h5>
        <a href="https://link.radioking.com/radio-odyssey" target="_blank" rel="noopener">RadioKing</a>
        <a href="https://tunein.com/radio/RADIO-ODYSSEY-s339104/" target="_blank" rel="noopener">TuneIn</a>
        <a href="https://www.deezer.com/search/radio%20odyssey/livestream" target="_blank" rel="noopener">Deezer</a>
        <a href="https://fr.welove.radio/radio/radio-odyssey/" target="_blank" rel="noopener">WeLoveRadio</a>
        <a href="https://radio.orange.com/radios/radio_odyssey" target="_blank" rel="noopener">Orange</a>
      </div>
      <div class="col-sm-6 col-lg-2">
        <h5>Partenaire</h5>
        <a href="/#partenaire">Santé Mentale Positive</a>
      </div>
    </div>
    <hr/>
    <div class="d-flex flex-wrap justify-content-between align-items-center gap-2">
      <div class="footer-bottom">© 2026 Radio Odyssey. Tous droits réservés. | Depuis le 19 janvier 2025 · <a href="/mentions-legales.html" style="color:inherit;text-decoration:underline;">Mentions légales</a> · <a href="/politique-de-confidentialite.html" style="color:inherit;text-decoration:underline;">Confidentialité</a> · <a href="#" onclick="window.roOpenCookiePreferences && window.roOpenCookiePreferences(); return false;" style="color:inherit;text-decoration:underline;">Gérer les cookies</a></div>
      <div class="footer-social d-flex gap-3">
        <a href="https://www.facebook.com/profile.php?id=61588289230589" target="_blank" rel="noopener" aria-label="Facebook"><Icon name="facebook" /></a>
        <a href="https://www.instagram.com/radio_odyssey_france/" target="_blank" rel="noopener" aria-label="Instagram"><Icon name="instagram" /></a>
        <a href="https://x.com/Odysseylaradio" target="_blank" rel="noopener" aria-label="X"><Icon name="twitter-x" /></a>
        <a href="https://www.youtube.com/channel/UCodzZ_dhFdJwQ90nZzVHluw" target="_blank" rel="noopener" aria-label="YouTube"><Icon name="youtube" /></a>
      </div>
    </div>
  </div>
</footer>

<script is:inline src="/assets/vendor/bootstrap-js/bootstrap.bundle.min.js"></script>
<script is:inline src="/assets/js/main.js"></script>

<script is:inline>
/* ── Radio Odyssey : lecture adaptée desktop/mobile ── */
function roUmamiTrack(name, data){
  if(typeof umami !== 'undefined' && umami.track){
    try { umami.track(name, data); } catch(err){}
  }
}

function roPlayNow(e){
  if(e){ e.preventDefault(); e.stopPropagation(); }

  var isMobile = /Mobi|Android|iPhone|iPad|iPod/i.test(navigator.userAgent)
                 || window.innerWidth <= 767;

  roUmamiTrack('play_click', { device: isMobile ? 'mobile' : 'desktop', page: location.pathname });

  if(isMobile){
    // Mobile : les navigateurs bloquent l'autoplay iframe.
    // On ouvre le player RadioKing dans un nouvel onglet —
    // il démarre immédiatement car c'est une action utilisateur directe.
    var win = window.open('https://link.radioking.com/radio-odyssey', '_blank');
    if(win){
      // Onglet externe : on ne peut pas observer la lecture réelle,
      // l'ouverture réussie (déclenchée par un geste utilisateur direct)
      // sert de proxy pour "lecture démarrée".
      roUmamiTrack('play_started', { device: 'mobile', method: 'external-tab' });
    } else {
      roUmamiTrack('play_error', { device: 'mobile', reason: 'popup_blocked' });
    }
    return;
  }

  // Desktop : recharger l'iframe avec autoplay
  var iframe = document.querySelector('#topRadioBar iframe.rk-desktop')
            || document.querySelector('#topRadioBar iframe');

  if(iframe){
    var src = 'https://player.radioking.io/radio-odyssey/?c=%231e7fcb&c2=%23ffffff&f=h&i=1&p=1&s=0&li=0&popup=0&h=90&a=1';
    iframe.addEventListener('load', function onLoad(){
      // Iframe cross-origin : on ne peut pas confirmer que l'audio joue
      // réellement (pas d'API postMessage exposée par RadioKing), le
      // chargement du lecteur avec le paramètre autoplay sert de proxy.
      roUmamiTrack('play_started', { device: 'desktop', method: 'iframe-reload' });
      iframe.removeEventListener('load', onLoad);
    });
    iframe.addEventListener('error', function onError(){
      roUmamiTrack('play_error', { device: 'desktop', reason: 'iframe_load_error' });
      iframe.removeEventListener('error', onError);
    }, { once: true });
    iframe.src = '';
    setTimeout(function(){ iframe.src = src; }, 50);
  } else {
    roUmamiTrack('play_error', { device: 'desktop', reason: 'iframe_not_found' });
  }
  window.scrollTo({top: 0, behavior: 'smooth'});
}
</script>
