<script is:inline>
/* ── Radio Odyssey : lecture adaptée desktop/mobile ── */
function roPlayNow(e){
  if(e){ e.preventDefault(); e.stopPropagation(); }

  var isMobile = /Mobi|Android|iPhone|iPad|iPod/i.test(navigator.userAgent)
                 || window.innerWidth <= 767;

  if(isMobile){
    // Mobile : les navigateurs bloquent l'autoplay iframe.
    // On ouvre le player RadioKing dans un nouvel onglet —
    // il démarre immédiatement car c'est une action utilisateur directe.
    window.open('https://link.radioking.com/radio-odyssey', '_blank');
    return;
  }

  // Desktop : recharger l'iframe avec autoplay
  var iframe = document.querySelector('#topRadioBar iframe.rk-desktop')
            || document.querySelector('#topRadioBar iframe');

  if(iframe){
    var src = 'https://player.radioking.io/radio-odyssey/?c=%231e7fcb&c2=%23ffffff&f=h&i=1&p=1&s=0&li=0&popup=0&h=90&a=1';
    iframe.src = '';
    setTimeout(function(){ iframe.src = src; }, 50);
  }
  window.scrollTo({top: 0, behavior: 'smooth'});
}
</script>
