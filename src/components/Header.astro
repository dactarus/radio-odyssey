---
import MegaNav from './MegaNav.astro';
import { NAV_CATEGORIES } from '../data/navigation.js';
---
<!-- ============================================================
     PLAYER BAR STICKY
     ============================================================ -->
<div id="topRadioBar">

  <!-- GAUCHE : logo + badge -->
  <a class="bar-logo" href="/" aria-label="Radio Odyssey — Accueil">
    <img class="bar-logo-img" src="/assets/images/logo.png" alt="Radio Odyssey"
         onerror="this.style.opacity='0'"/>
  </a>
  <div class="live-badge">
    <span class="live-dot"></span>
    EN DIRECT
  </div>

  <!-- CENTRE desktop : player RadioKing h=90 (original) -->
  <iframe class="rk-desktop"
    src="https://player.radioking.io/radio-odyssey/?c=%231e7fcb&c2=%23ffffff&f=h&i=1&p=1&s=0&li=0&popup=0&h=90"
    allow="autoplay" title="Radio Odyssey — Lecteur en direct"></iframe>

  <!-- BOUTON mobile alternatif (affiché si iframe trop petite) -->
  <a class="rk-mobile-btn" href="https://link.radioking.com/radio-odyssey" target="_blank" rel="noopener"
     aria-label="Écouter Radio Odyssey">
    <span class="rk-mobile-play">&#9654;</span>
    <span class="rk-mobile-label">
      <span class="rk-mobile-title" id="mobile-now-playing">Radio Odyssey</span>
      <span class="rk-mobile-sub">Appuyer pour écouter</span>
    </span>
  </a>

  <!-- DROITE : wave + burger -->
  <div class="bar-wave" aria-hidden="true">
    <span></span><span></span><span></span>
    <span></span><span></span><span></span><span></span>
  </div>
  <button class="bar-burger"
          data-bs-toggle="offcanvas"
          data-bs-target="#site-nav"
          aria-controls="site-nav"
          aria-label="Ouvrir le menu"
          style="margin-right:16px;">
    <i class="bi bi-list"></i>
  </button>

</div>

<!-- Script RadioKing (original) -->
<script is:inline src="https://player.radioking.io/scripts/iframe.bundle.js"></script>

<!-- ============================================================
     MEGA-MENU (desktop)
     ============================================================ -->
<MegaNav />

<!-- ============================================================
     OFFCANVAS NAV (mobile)
     ============================================================ -->
<div class="offcanvas offcanvas-start" id="site-nav" tabindex="-1" aria-labelledby="nav-label">
  <div class="offcanvas-header">
    <div class="offcanvas-title" id="nav-label">
      <img src="/assets/images/logo.png" alt="Logo Radio Odyssey"/>
      Radio Odyssey
    </div>
    <button type="button" class="btn-close" data-bs-dismiss="offcanvas" aria-label="Fermer"></button>
  </div>
  <div class="offcanvas-body p-2">

    <span class="nav-cat"><i class="bi bi-house-door-fill"></i> Accueil</span>
    <a class="nav-link" href="/"><span class="ni"><i class="bi bi-house-door-fill"></i></span> Page d'accueil</a>

    {NAV_CATEGORIES.map((cat) => (
      <>
        <span class="nav-cat"><i class={`bi bi-${cat.bi}`}></i> {cat.label}</span>
        <a class="nav-link" href={cat.hub}><span class="ni"><i class="bi bi-search"></i></span> <strong>Voir tout</strong></a>
        {cat.pages.map((p) => (
          <a class="nav-link" href={p.href}><span class="ni"><i class={`bi bi-${p.bi}`}></i></span> {p.label}</a>
        ))}
      </>
    ))}

    <div class="offcanvas-cta">
      <a class="btn-ro w-100 justify-content-center"
         href="https://link.radioking.com/radio-odyssey" target="_blank" rel="noopener">
        <i class="bi bi-broadcast"></i>&nbsp; Écouter en Direct
      </a>
    </div>
  </div>
</div>
