---
// Vidéo YouTube d'Elisabeth Bélot-Grimaud (séance de cohérence cardiaque
// en musique) — réutilisée sur plusieurs pages plutôt que dupliquée en dur.
interface Props {
  heading?: string;
  intro?: string;
}
const {
  heading = 'Écoutez sa voix, en vidéo',
  intro = "Elisabeth Bélot-Grimaud a mis en ligne sur sa chaîne YouTube une séance de cohérence cardiaque en musique — le même exercice, la même voix que celle diffusée sur l'antenne de Radio Odyssey.",
} = Astro.props;

const videoSchema = {
  '@context': 'https://schema.org',
  '@type': 'VideoObject',
  name: 'Instant Nature 5/5 | Cohérence cardiaque en musique – Dr. Élisabeth Bélot, PhD.',
  description: "Une séance guidée de cohérence cardiaque en musique, présentée par Elisabeth Bélot-Grimaud — le même exercice que celui diffusé sur l'antenne de Radio Odyssey.",
  thumbnailUrl: 'https://i.ytimg.com/vi/2ULLb_D82VA/hqdefault.jpg',
  embedUrl: 'https://www.youtube.com/embed/2ULLb_D82VA',
  publisher: {
    '@type': 'Person',
    name: 'Elisabeth Bélot-Grimaud',
  },
};
---
<div class="content-card" id="video" style="scroll-margin-top:200px;">
  <h2>{heading}</h2>
  <p>{intro}</p>
  <div style="position:relative;padding-bottom:56.25%;height:0;overflow:hidden;border-radius:16px;margin-top:1rem;">
    <iframe
      src="https://www.youtube.com/embed/2ULLb_D82VA"
      title="Instant Nature 5/5 | Cohérence cardiaque en musique – Dr. Élisabeth Bélot, PhD."
      style="position:absolute;top:0;left:0;width:100%;height:100%;border:0;"
      allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
      loading="lazy"
      allowfullscreen
    ></iframe>
  </div>
</div>

<script type="application/ld+json" is:inline set:html={JSON.stringify(videoSchema)} />
